      status: 'present' | 'absent' | 'late' | 'excused';
      method: 'biometric' | 'rfid' | 'manual' | 'mobile';
      location: {
        latitude: number;
        longitude: number;
        address: string;
        isWithinGeofence: boolean;
      };
      biometricData: {
        facialRecognition: boolean;
        fingerprintMatch: boolean;
        confidence: number;
      };
      deviceInfo: {
