      approvedAt?: string;
      attachments: string[];
      createdAt: string;
    }>,
    notifications: [] as Array<{
      id: string;
      type: 'absence_alert' | 'late_arrival' | 'geofence_breach' | 'biometric_failure';
      studentId: number;
      message: string;
      severity: 'low' | 'medium' | 'high' | 'critical';
