  ]);
  const [showColumnSettings, setShowColumnSettings] = useState(false);
  const [columnSettings, setColumnSettings] = useState({
    availableColumns: [
      { key: 'select', label: 'Select', fixed: true },
      { key: 'photo', label: 'Photo', fixed: false },
