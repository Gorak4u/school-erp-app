  @@index([userId, isRead])
  @@index([schoolId])
  @@index([createdAt(sort: Desc)])
  @@index([schoolId, channel, deliveryStatus])
  @@index([dedupeKey])
  @@schema("school")
}

model CommunicationOutbox {
