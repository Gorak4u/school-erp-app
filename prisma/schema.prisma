generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["saas", "school"]
}

model School {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  domain       String?       @unique
  email        String
  phone        String?
  address      String?
  city         String?
  state        String?
  pinCode      String?
  logo         String?
  isActive     Boolean       @default(true)
  isDemo       Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  subscription Subscription?
  customRoles  CustomRole[]
  students     Student[]
  teachers     Teacher[]
  User         school_User[]

  @@index([slug])
  @@index([isActive])
  @@index([isDemo])
  @@schema("saas")
}

model Subscription {
  id                   String                @id @default(cuid())
  schoolId             String                @unique
  plan                 String                @default("trial")
  status               String                @default("trial")
  trialEndsAt          DateTime?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  maxStudents          Int                   @default(50)
  maxTeachers          Int                   @default(5)
  features             String                @default("[]")
  billingCycle         String                @default("monthly")
  price                Int                   @default(0)
  billingEmail         String?
  paymentMethod        String?
  paymentId            String?
  autoRenew            Boolean               @default(false)
  cancelledAt          DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  razorpayOrderId      String?
  razorpayPaymentId    String?
  invoices             Invoice[]
  school               School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subscriptionPayments SubscriptionPayment[]

  @@index([plan])
  @@index([status])
  @@index([trialEndsAt])
  @@schema("saas")
}

model Invoice {
  id             String       @id @default(cuid())
  subscriptionId String
  amount         Float
  currency       String       @default("INR")
  status         String       @default("pending")
  description    String?
  paymentMethod  String?
  transactionId  String?
  paidAt         DateTime?
  dueDate        DateTime
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([status])
  @@index([dueDate])
  @@schema("saas")
}

model Plan {
  id           String   @id @default(cuid())
  name         String   @unique
  displayName  String
  description  String?
  priceMonthly Float    @default(0)
  priceYearly  Float    @default(0)
  currency     String   @default("INR")
  maxStudents  Int      @default(50)
  maxTeachers  Int      @default(5)
  features     String   @default("[]")
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  trialDays    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([name])
  @@index([isActive])
  @@schema("saas")
}

model CustomRole {
  id          String        @id @default(cuid())
  name        String
  description String?
  permissions String        @default("[]")
  schoolId    String?
  isDefault   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  school      School?       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  User        school_User[]

  @@unique([name, schoolId])
  @@index([schoolId])
  @@schema("school")
}

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()"))
  email        String    @unique
  name         String
  password     String
  role         String    @default("super_admin")
  isActive     Boolean?  @default(true)
  isSuperAdmin Boolean?  @default(false)
  createdAt    DateTime? @default(now()) @db.Timestamp(6)
  updatedAt    DateTime? @default(now()) @updatedAt @db.Timestamp(6)

  @@index([email])
  @@index([role])
  @@schema("saas")
}

model VerificationToken {
  identifier String
  token      String    @unique
  expires    DateTime  @db.Timestamp(6)
  createdAt  DateTime? @default(now()) @db.Timestamp(6)
  updatedAt  DateTime? @default(now()) @db.Timestamp(6)

  @@unique([identifier, token])
  @@schema("saas")
}

model SaasSetting {
  id        String   @id @default(cuid())
  group     String
  key       String
  value     String   @default("")
  updatedAt DateTime @updatedAt

  @@unique([group, key])
  @@index([group])
  @@schema("saas")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorEmail String
  action     String
  target     String?
  targetName String?
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([actorEmail])
  @@index([action])
  @@index([createdAt])
  @@schema("saas")
}

model SaasAnnouncement {
  id          String    @id @default(cuid())
  title       String
  message     String
  type        String    @default("info")
  targetPlans String?
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive])
  @@index([createdAt])
  @@schema("saas")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
  @@schema("saas")
}

model Student {
  id                    String             @id @default(cuid())
  admissionNo           String             @unique
  name                  String
  email                 String?
  photo                 String?
  class                 String
  section               String
  rollNo                String
  gender                String
  dateOfBirth           String
  status                String             @default("active")
  phone                 String?
  address               String?
  city                  String?
  state                 String?
  pinCode               String?
  nationality           String?
  religion              String?
  category              String?
  motherTongue          String?
  languageMedium        String?
  bloodGroup            String?
  aadharNumber          String?
  stsId                 String?
  board                 String?
  emergencyContact      String?
  emergencyRelation     String?
  medicalConditions     String?
  allergies             String?
  medications           String?
  doctorName            String?
  doctorPhone           String?
  transport             String?
  transportRoute        String?
  hostel                String?
  sibling               String?
  siblingName           String?
  siblingClass          String?
  parentName            String?
  parentPhone           String?
  parentEmail           String?
  fatherName            String?
  fatherOccupation      String?
  fatherPhone           String?
  fatherEmail           String?
  motherName            String?
  motherOccupation      String?
  motherPhone           String?
  motherEmail           String?
  guardianName          String?
  guardianRelation      String?
  guardianPhone         String?
  previousSchool        String?
  previousClass         String?
  previousSchoolName    String?
  previousSchoolAddress String?
  previousSchoolPhone   String?
  previousSchoolEmail   String?
  transferCertificate   String?
  transferCertificateNo String?
  bankName              String?
  bankAccountNumber     String?
  bankIfsc              String?
  documents             String?
  gpa                   Float              @default(0)
  rank                  Int                @default(0)
  disciplineScore       Int                @default(100)
  incidents             Int                @default(0)
  achievements          Int                @default(0)
  remarks               String?
  admissionDate         String?
  enrollmentDate        String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  academicYear          String             @default("2024-25")
  academicYearId        String?            // FK to AcademicYear — set on admission & promotion
  schoolId              String?
  attendanceRecords     AttendanceRecord[]
  examResults           ExamResult[]
  feeRecords            FeeRecord[]
  promotions            StudentPromotion[]
  arrears               FeeArrears[]
  school                School?            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYearRef       AcademicYear?      @relation("StudentAcademicYear", fields: [academicYearId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([class])
  @@index([status])
  @@index([gender])
  @@index([class, status])
  @@index([name])
  @@index([admissionNo])
  @@index([createdAt])
  @@index([parentName])
  @@index([academicYear])
  @@index([academicYearId])
  @@index([class, academicYear])
  @@index([status, academicYear])
  @@index([name, class])
  @@index([rollNo])
  @@index([email])
  @@schema("school")
}

model Teacher {
  id                String             @id @default(cuid())
  employeeId        String             @unique
  name              String
  email             String             @unique
  phone             String?
  gender            String?
  dateOfBirth       String?
  subject           String?
  qualification     String?
  experience        Int?               @default(0)
  status            String             @default("active")
  address           String?
  photo             String?
  joiningDate       String?
  salary            Float?
  department        String?
  designation       String?
  bloodGroup        String?
  aadharNumber      String?
  bankName          String?
  bankAccountNo     String?
  bankIfsc          String?
  emergencyName     String?
  emergencyPhone    String?
  remarks           String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  userId            String?            @unique
  schoolId          String?
  attendanceRecords AttendanceRecord[]
  school            School?            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user              school_User?       @relation(fields: [userId], references: [id])

  @@index([schoolId])
  @@index([status])
  @@index([department])
  @@index([name])
  @@index([createdAt])
  @@schema("school")
}

model FeeStructure {
  id                   String        @id @default(cuid())
  name                 String
  category             String
  amount               Float
  frequency            String
  dueDate              Int           @default(1)
  lateFee              Float         @default(0)
  description          String?
  applicableCategories String        @default("all")
  isActive             Boolean       @default(true)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  academicYearId       String?
  boardId              String?
  classId              String?
  mediumId             String?
  schoolId             String?
  feeRecords           FeeRecord[]
  academicYear         AcademicYear? @relation(fields: [academicYearId], references: [id])
  board                Board?        @relation(fields: [boardId], references: [id])
  class                Class?        @relation(fields: [classId], references: [id])
  medium               Medium?       @relation(fields: [mediumId], references: [id])

  @@index([schoolId])
  @@index([academicYearId])
  @@index([boardId])
  @@index([mediumId])
  @@index([classId])
  @@index([isActive])
  @@index([academicYearId, boardId, mediumId, classId])
  @@schema("school")
}

model FeeRecord {
  id             String       @id @default(cuid())
  studentId      String
  feeStructureId String
  amount         Float
  paidAmount     Float        @default(0)
  pendingAmount  Float
  discount       Float        @default(0)
  dueDate        String
  paidDate       String?
  status         String       @default("pending")
  paymentMethod  String?
  transactionId  String?
  receiptNumber  String?      @unique
  collectedBy    String?
  academicYear   String       @default("2024-25")
  remarks        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id])
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payments       Payment[]

  @@index([studentId])
  @@index([status])
  @@index([academicYear])
  @@index([dueDate])
  @@index([studentId, status])
  @@index([studentId, academicYear])
  @@index([status, academicYear])
  @@index([dueDate, status])
  @@index([createdAt])
  @@index([paymentMethod])
  @@schema("school")
}

model Payment {
  id            String    @id @default(cuid())
  feeRecordId   String
  amount        Float
  paymentMethod String
  transactionId String?
  receiptNumber String    @unique
  paymentDate   String
  collectedBy   String?
  remarks       String?
  createdAt     DateTime  @default(now())
  feeRecord     FeeRecord @relation(fields: [feeRecordId], references: [id], onDelete: Cascade)

  @@index([paymentDate])
  @@index([collectedBy])
  @@index([paymentMethod])
  @@index([collectedBy, paymentMethod])
  @@index([paymentDate, amount])
  @@index([feeRecordId])
  @@index([createdAt])
  @@schema("school")
}

model SubscriptionPayment {
  id             String       @id @default(cuid())
  subscriptionId String
  orderId        String
  paymentId      String?
  amount         Float
  currency       String       @default("INR")
  status         String       @default("pending")
  paymentMethod  String       @default("razorpay")
  receiptNumber  String
  paymentDate    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([orderId])
  @@index([paymentId])
  @@schema("saas")
}

model Discount {
  id                   String   @id @default(cuid())
  name                 String
  type                 String
  value                Float
  applicableClasses    String
  applicableCategories String
  maxDiscountAmount    Float?
  isActive             Boolean  @default(true)
  validFrom            String
  validTo              String
  description          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  schoolId             String?

  @@index([schoolId])
  @@schema("school")
}

model AttendanceRecord {
  id        String   @id @default(cuid())
  studentId String
  teacherId String?
  date      String
  status    String
  subject   String?
  class     String?
  section   String?
  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher   Teacher? @relation(fields: [teacherId], references: [id])

  @@unique([studentId, date, subject])
  @@index([date])
  @@index([class])
  @@index([studentId])
  @@index([class, date])
  @@index([status])
  @@schema("school")
}

model Exam {
  id           String       @id @default(cuid())
  name         String
  type         String
  class        String
  section      String?
  subject      String
  date         String
  duration     Int
  totalMarks   Float
  passingMarks Float
  academicYear String       @default("2024-25")
  status       String       @default("scheduled")
  venue        String?
  instructions String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  schoolId     String?
  results      ExamResult[]

  @@index([schoolId])
  @@index([class])
  @@index([status])
  @@index([academicYear])
  @@index([date])
  @@index([class, academicYear])
  @@schema("school")
}

model ExamResult {
  id            String   @id @default(cuid())
  examId        String
  studentId     String
  marksObtained Float
  grade         String?
  remarks       String?
  isAbsent      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
  @@schema("school")
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  content     String
  type        String    @default("general")
  targetRoles String
  isActive    Boolean   @default(true)
  publishedAt DateTime  @default(now())
  expiresAt   DateTime?
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@schema("school")
}

model AcademicYear {
  id            String         @id @default(cuid())
  year          String         @unique
  name          String
  startDate     String
  endDate       String
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  classes       Class[]
  feeStructures FeeStructure[]
  mediums       Medium[]
  sections      Section[]
  students      Student[]      @relation("StudentAcademicYear")

  @@index([year])
  @@index([isActive])
  @@schema("school")
}

model Medium {
  id             String         @id @default(cuid())
  code           String         @unique
  name           String
  description    String?
  isActive       Boolean        @default(true)
  academicYearId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  classes        Class[]
  feeStructures  FeeStructure[]
  academicYear   AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([isActive])
  @@index([academicYearId])
  @@schema("school")
}

model Class {
  id             String         @id @default(cuid())
  code           String         @unique
  name           String
  level          String
  mediumId       String
  academicYearId String
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  academicYear   AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  medium         Medium         @relation(fields: [mediumId], references: [id], onDelete: Cascade)
  feeStructures  FeeStructure[]
  sections       Section[]

  @@index([code])
  @@index([level])
  @@index([isActive])
  @@index([mediumId])
  @@index([academicYearId])
  @@schema("school")
}

model Section {
  id             String       @id @default(cuid())
  code           String       @unique
  name           String
  classId        String
  capacity       Int
  roomNumber     String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  class          Class        @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([isActive])
  @@index([classId])
  @@index([academicYearId])
  @@schema("school")
}

model SchoolSetting {
  id        String   @id @default(cuid())
  schoolId  String   @default("default")
  group     String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, group, key])
  @@index([schoolId])
  @@index([group])
  @@schema("school")
}

model Board {
  id            String         @id @default(cuid())
  code          String         @unique
  name          String
  description   String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  feeStructures FeeStructure[]

  @@index([code])
  @@index([isActive])
  @@schema("school")
}

model SchoolTiming {
  id        String   @id @default(cuid())
  name      String
  type      String
  startTime String
  endTime   String
  dayOfWeek String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([dayOfWeek])
  @@index([sortOrder])
  @@schema("school")
}

model Account {
  id                String      @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              school_User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@schema("school")
}

model Session {
  id           String      @id
  sessionToken String      @unique
  userId       String
  expires      DateTime
  User         school_User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("school")
}

model school_User {
  id           String      @id
  email        String      @unique
  password     String
  firstName    String
  lastName     String
  role         String      @default("admin")
  avatar       String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime
  customRoleId String?
  schoolId     String?
  Account      Account[]
  Session      Session[]
  teacher      Teacher?
  CustomRole   CustomRole? @relation(fields: [customRoleId], references: [id])
  School       School?     @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([customRoleId])
  @@index([schoolId])
  @@map("User")
  @@schema("school")
}

model school_VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("VerificationToken")
  @@schema("school")
}

model DiscountRequest {
  id               String   @id @default(cuid())
  schoolId         String

  // What discount
  name             String
  description      String?
  discountType     String   // "percentage" | "fixed" | "full_waiver"
  discountValue    Float
  maxCapAmount     Float?

  // Scope of application
  scope            String   // "student" | "class" | "bulk"
  targetType       String   // "fee_structure" | "total"
  feeStructureIds  String   @default("[]")
  studentIds       String   @default("[]")
  classIds         String   @default("[]")
  sectionIds       String   @default("[]")
  academicYear     String

  // Reason / justification
  reason           String
  supportingDoc    String?

  // Workflow status
  status           String   @default("pending") // "pending"|"approved"|"rejected"|"cancelled"|"applied"

  // Requester
  requestedBy      String
  requestedByEmail String
  requestedByName  String
  requestedAt      DateTime @default(now())

  // Approver
  approvedBy       String?
  approvedByEmail  String?
  approvedByName   String?
  approvedAt       DateTime?
  approvalNote     String?

  // Rejection
  rejectedBy       String?
  rejectedByEmail  String?
  rejectedAt       DateTime?
  rejectionReason  String?

  // Applied
  appliedBy        String?
  appliedByEmail   String?
  appliedAt        DateTime?
  appliedCount     Int?

  // Validity
  validFrom        String
  validTo          String

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  applications     DiscountApplication[]
  auditLogs        DiscountRequestAuditLog[]

  @@index([schoolId])
  @@index([schoolId, status])
  @@index([schoolId, academicYear])
  @@index([schoolId, status, academicYear])
  @@index([requestedBy])
  @@index([approvedBy])
  @@index([status])
  @@index([createdAt])
  @@schema("school")
}

model DiscountApplication {
  id                String          @id @default(cuid())
  schoolId          String

  discountRequestId String
  discountRequest   DiscountRequest @relation(fields: [discountRequestId], references: [id], onDelete: Cascade)

  studentId         String
  feeRecordId       String
  feeStructureId    String?

  discountAmount    Float
  previousDiscount  Float

  // Reversal support
  isReversed        Boolean  @default(false)
  reversedBy        String?
  reversedByEmail   String?
  reversedAt        DateTime?
  reversalReason    String?

  appliedAt         DateTime @default(now())
  appliedBy         String
  appliedByEmail    String

  @@index([schoolId])
  @@index([schoolId, studentId])
  @@index([discountRequestId])
  @@index([studentId])
  @@index([feeRecordId])
  @@index([studentId, feeRecordId])
  @@index([schoolId, isReversed])
  @@schema("school")
}

model DiscountRequestAuditLog {
  id                String          @id @default(cuid())
  schoolId          String

  discountRequestId String
  discountRequest   DiscountRequest @relation(fields: [discountRequestId], references: [id], onDelete: Cascade)

  action            String          // "created"|"approved"|"rejected"|"cancelled"|"applied"|"reversed"|"modified"
  actorUserId       String
  actorEmail        String
  actorName         String
  actorRole         String

  previousStatus    String?
  newStatus         String?
  details           String?
  ipAddress         String?

  createdAt         DateTime @default(now())

  @@index([schoolId])
  @@index([discountRequestId])
  @@index([schoolId, createdAt])
  @@index([actorEmail])
  @@index([action])
  @@schema("school")
}

model StudentPromotion {
  id               String   @id @default(cuid())
  schoolId         String
  studentId        String
  fromClass        String
  toClass          String
  fromSection      String
  toSection        String
  fromAcademicYear String
  toAcademicYear   String
  promotedBy       String
  promotedByEmail  String
  promotedByName   String
  promotionType    String   @default("regular")
  arrearsAmount    Float    @default(0)
  remarks          String?
  promotionDate    DateTime @default(now())
  createdAt        DateTime @default(now())
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([schoolId])
  @@index([fromAcademicYear])
  @@index([toAcademicYear])
  @@index([promotionDate])
  @@schema("school")
}

model FeeArrears {
  id                  String   @id @default(cuid())
  schoolId            String
  studentId           String
  originalFeeRecordId String
  fromAcademicYear    String
  toAcademicYear      String
  amount              Float
  paidAmount          Float    @default(0)
  pendingAmount       Float
  dueDate             String
  status              String   @default("pending")
  remarks             String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  student             Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([schoolId])
  @@index([fromAcademicYear])
  @@index([toAcademicYear])
  @@index([status])
  @@schema("school")
}

// Token blacklist for production JWT invalidation
model TokenBlacklist {
  id        String    @id @default(cuid())
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  
  @@index([expiresAt])
  @@schema("school")
}
