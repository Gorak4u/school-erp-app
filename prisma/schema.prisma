generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Multi-Tenant School & Subscription ───

model School {
  id             String        @id @default(cuid())
  name           String
  slug           String        @unique // URL-friendly identifier
  domain         String?       @unique // optional custom domain
  email          String
  phone          String?
  address        String?
  city           String?
  state          String?
  pinCode        String?
  logo           String?
  isActive       Boolean       @default(true)
  isDemo         Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  subscription   Subscription?
  users          User[]
  students       Student[]
  teachers       Teacher[]

  @@index([slug])
  @@index([isActive])
  @@index([isDemo])
}

model Subscription {
  id                String   @id @default(cuid())
  schoolId          String   @unique
  plan              String   @default("trial") // trial, basic, professional, enterprise
  status            String   @default("trial") // trial, active, past_due, expired, cancelled
  trialEndsAt       DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  maxStudents       Int      @default(50)
  maxTeachers       Int      @default(5)
  features          String   @default("[]") // JSON array of enabled feature keys
  billingEmail      String?
  paymentMethod     String?  // razorpay, stripe, manual
  paymentId         String?  // external payment provider ID
  cancelledAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  school            School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  invoices          Invoice[]

  @@index([plan])
  @@index([status])
  @@index([trialEndsAt])
}

model Invoice {
  id              String   @id @default(cuid())
  subscriptionId  String
  amount          Float
  currency        String   @default("INR")
  status          String   @default("pending") // pending, paid, failed, refunded
  description     String?
  paymentMethod   String?
  transactionId   String?
  paidAt          DateTime?
  dueDate         DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([status])
  @@index([dueDate])
}

model Plan {
  id              String   @id @default(cuid())
  name            String   @unique // trial, basic, professional, enterprise
  displayName     String
  description     String?
  priceMonthly    Float    @default(0)
  priceYearly     Float    @default(0)
  currency        String   @default("INR")
  maxStudents     Int      @default(50)
  maxTeachers     Int      @default(5)
  features        String   @default("[]") // JSON array of feature keys
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  trialDays       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([name])
  @@index([isActive])
}

// ─── User ───

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  firstName String
  lastName  String
  role      String    @default("admin")
  avatar    String?
  isActive  Boolean   @default(true)
  schoolId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  school    School?   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  accounts  Account[]
  sessions  Session[]
  teacher   Teacher?

  @@index([schoolId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Platform-level SaaS settings (SMTP, payment gateway, branding)
// Completely separate from per-school SchoolSetting
model SaasSetting {
  id        String   @id @default(cuid())
  group     String   // saas_smtp, saas_payment, saas_general
  key       String
  value     String   @default("")
  updatedAt DateTime @updatedAt

  @@unique([group, key])
  @@index([group])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

model Student {
  id                    String             @id @default(cuid())
  admissionNo           String             @unique
  name                  String
  email                 String?
  photo                 String?
  class                 String
  section               String
  rollNo                String
  gender                String
  dateOfBirth           String
  status                String             @default("active")
  schoolId              String?
  phone                 String?
  address               String?
  city                  String?
  state                 String?
  pinCode               String?
  nationality           String?
  religion              String?
  category              String?
  motherTongue          String?
  languageMedium        String?
  bloodGroup            String?
  aadharNumber          String?
  stsId                 String?
  board                 String?
  emergencyContact      String?
  emergencyRelation     String?
  medicalConditions     String?
  allergies             String?
  medications           String?
  doctorName            String?
  doctorPhone           String?
  transport             String?
  transportRoute        String?
  hostel                String?
  sibling               String?
  siblingName           String?
  siblingClass          String?
  parentName            String?
  parentPhone           String?
  parentEmail           String?
  fatherName            String?
  fatherOccupation      String?
  fatherPhone           String?
  fatherEmail           String?
  motherName            String?
  motherOccupation      String?
  motherPhone           String?
  motherEmail           String?
  guardianName          String?
  guardianRelation      String?
  guardianPhone         String?
  previousSchool        String?
  previousClass         String?
  previousSchoolName    String?
  previousSchoolAddress String?
  previousSchoolPhone   String?
  previousSchoolEmail   String?
  transferCertificate   String?
  transferCertificateNo String?
  bankName              String?
  bankAccountNumber     String?
  bankIfsc              String?
  documents             String?
  gpa                   Float              @default(0)
  rank                  Int                @default(0)
  disciplineScore       Int                @default(100)
  incidents             Int                @default(0)
  achievements          Int                @default(0)
  remarks               String?
  admissionDate         String?
  enrollmentDate        String?
  academicYear         String             @default("2024-25")
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  school                School?            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  attendanceRecords     AttendanceRecord[]
  examResults           ExamResult[]
  feeRecords            FeeRecord[]

  @@index([schoolId])
  @@index([class])
  @@index([status])
  @@index([gender])
  @@index([class, status])
  @@index([name])
  @@index([admissionNo])
  @@index([createdAt])
  @@index([parentName])
  @@index([academicYear])
}

model Teacher {
  id                String             @id @default(cuid())
  employeeId        String             @unique
  name              String
  email             String             @unique
  phone             String?
  gender            String?
  dateOfBirth       String?
  subject           String?
  qualification     String?
  experience        Int?               @default(0)
  status            String             @default("active")
  schoolId          String?
  address           String?
  photo             String?
  joiningDate       String?
  salary            Float?
  department        String?
  designation       String?
  bloodGroup        String?
  aadharNumber      String?
  bankName          String?
  bankAccountNo     String?
  bankIfsc          String?
  emergencyName     String?
  emergencyPhone    String?
  remarks           String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  userId            String?            @unique
  school            School?            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  attendanceRecords AttendanceRecord[]
  user              User?              @relation(fields: [userId], references: [id])

  @@index([schoolId])
  @@index([status])
  @@index([department])
  @@index([name])
  @@index([createdAt])
}

model FeeStructure {
  id                   String      @id @default(cuid())
  name                 String
  category             String      // tuition, transport, lab, exam, hostel, activity, other
  amount               Float
  frequency            String      // monthly, quarterly, half_yearly, annually, one_time
  dueDate              Int         @default(1)
  lateFee              Float       @default(0)
  description          String?
  applicableCategories String      @default("all")
  isActive             Boolean     @default(true)

  // FK relations to school structure
  academicYearId       String
  boardId              String?
  mediumId             String?
  classId              String?

  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  academicYear         AcademicYear @relation(fields: [academicYearId], references: [id])
  board                Board?       @relation(fields: [boardId], references: [id])
  medium               Medium?      @relation(fields: [mediumId], references: [id])
  class                Class?       @relation(fields: [classId], references: [id])
  feeRecords           FeeRecord[]

  @@index([academicYearId])
  @@index([boardId])
  @@index([mediumId])
  @@index([classId])
  @@index([isActive])
  @@index([academicYearId, boardId, mediumId, classId])
}

model FeeRecord {
  id             String       @id @default(cuid())
  studentId      String
  feeStructureId String
  amount         Float
  paidAmount     Float        @default(0)
  pendingAmount  Float
  discount       Float        @default(0)
  dueDate        String
  paidDate       String?
  status         String       @default("pending")
  paymentMethod  String?
  transactionId  String?
  receiptNumber  String?      @unique
  collectedBy    String?
  academicYear   String       @default("2024-25")
  remarks        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id])
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payments       Payment[]

  @@index([studentId])
  @@index([status])
  @@index([academicYear])
  @@index([dueDate])
  @@index([studentId, status])
  @@index([createdAt])
}

model Payment {
  id            String    @id @default(cuid())
  feeRecordId   String
  amount        Float
  paymentMethod String
  transactionId String?
  receiptNumber String    @unique
  paymentDate   String
  collectedBy   String?
  remarks       String?
  createdAt     DateTime  @default(now())
  feeRecord     FeeRecord @relation(fields: [feeRecordId], references: [id], onDelete: Cascade)
}

model Discount {
  id                   String   @id @default(cuid())
  name                 String
  type                 String
  value                Float
  applicableClasses    String
  applicableCategories String
  maxDiscountAmount    Float?
  isActive             Boolean  @default(true)
  validFrom            String
  validTo              String
  description          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model AttendanceRecord {
  id        String   @id @default(cuid())
  studentId String
  teacherId String?
  date      String
  status    String
  subject   String?
  class     String?
  section   String?
  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher   Teacher? @relation(fields: [teacherId], references: [id])

  @@unique([studentId, date, subject])
  @@index([date])
  @@index([class])
  @@index([studentId])
  @@index([class, date])
  @@index([status])
}

model Exam {
  id           String       @id @default(cuid())
  name         String
  type         String
  class        String
  section      String?
  subject      String
  date         String
  duration     Int
  totalMarks   Float
  passingMarks Float
  academicYear String       @default("2024-25")
  status       String       @default("scheduled")
  venue        String?
  instructions String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  results      ExamResult[]

  @@index([class])
  @@index([status])
  @@index([academicYear])
  @@index([date])
  @@index([class, academicYear])
}

model ExamResult {
  id            String   @id @default(cuid())
  examId        String
  studentId     String
  marksObtained Float
  grade         String?
  remarks       String?
  isAbsent      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  content     String
  type        String    @default("general")
  targetRoles String
  isActive    Boolean   @default(true)
  publishedAt DateTime  @default(now())
  expiresAt   DateTime?
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// School Structure Tables
model AcademicYear {
  id          String   @id @default(cuid())
  year        String   @unique
  name        String
  startDate   String
  endDate     String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mediums        Medium[]
  classes        Class[]
  feeStructures  FeeStructure[]

  @@index([year])
  @@index([isActive])
}

model Medium {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  description   String?
  isActive      Boolean  @default(true)
  academicYearId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  academicYear  AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  classes        Class[]
  feeStructures  FeeStructure[]

  @@index([code])
  @@index([isActive])
  @@index([academicYearId])
}

model Class {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  level         String   // kindergarten, primary, middle, high, higher_secondary
  mediumId      String
  academicYearId String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  medium         Medium @relation(fields: [mediumId], references: [id], onDelete: Cascade)
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  sections       Section[]
  feeStructures  FeeStructure[]

  @@index([code])
  @@index([level])
  @@index([isActive])
  @@index([mediumId])
  @@index([academicYearId])
}

model Section {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  classId     String
  capacity    Int
  roomNumber  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  class       Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([isActive])
  @@index([classId])
}

// Key-value store for all school/app settings
model SchoolSetting {
  id        String   @id @default(cuid())
  group     String   // school_details, smtp, payment_gateway, app_config, access_rights
  key       String
  value     String   // JSON string
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([group, key])
  @@index([group])
}

model Board {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  feeStructures  FeeStructure[]

  @@index([code])
  @@index([isActive])
}

model SchoolTiming {
  id          String   @id @default(cuid())
  name        String   // e.g. "Period 1", "Lunch Break"
  type        String   // period, break, assembly
  startTime   String   // "08:00"
  endTime     String   // "08:45"
  dayOfWeek   String   // mon,tue,wed,thu,fri,sat  or "all"
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([dayOfWeek])
  @@index([sortOrder])
}
