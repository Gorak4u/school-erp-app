// ========================================
// REFUND SYSTEM MODELS
// ========================================

model RefundRequest {
  id              String   @id @default(cuid())
  schoolId        String
  studentId       String
  type            String   // 'academic_fee', 'transport_fee', 'fine', 'overpayment'
  sourceId        String?  // feeRecordId, fineId, studentTransportId
  sourceType      String?  // 'FeeRecord', 'Fine', 'StudentTransport'
  amount          Float
  adminFee        Float    @default(0)
  netAmount       Float    // amount - adminFee
  reason          String
  status          String   @default("pending") // 'pending', 'approved', 'rejected', 'processed'
  priority        String   @default("normal") // 'low', 'normal', 'high'
  refundMethod    String   // 'bank_transfer', 'credit_future', 'cash'
  bankDetails     Json?    // Account info for bank transfers
  approvedBy      String?
  approvedAt      DateTime?
  processedBy     String?
  processedAt     DateTime?
  rejectionReason String?
  metadata        Json?    // Proration calculations, etc.
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  student         Student  @relation(fields: [studentId], references: [id])
  approvals       RefundApproval[]
  
  @@index([schoolId, status])
  @@index([studentId, status])
  @@index([type, status])
  @@index([priority, status])
  @@schema("school")
}

model RefundApproval {
  id            String   @id @default(cuid())
  refundId      String
  approverId    String
  approverRole  String
  action        String   // 'approved', 'rejected'
  comments      String?
  createdAt     DateTime @default(now())
  
  refund        RefundRequest @relation(fields: [refundId], references: [id], onDelete: Cascade)
  
  @@index([refundId])
  @@schema("school")
}

model RefundTransaction {
  id              String   @id @default(cuid())
  refundId        String
  amount          Float
  method          String
  transactionId   String?  // Bank transfer ID, cash receipt ID
  status          String   @default("pending") // 'pending', 'completed', 'failed'
  processedBy     String?
  processedAt     DateTime?
  failureReason   String?
  createdAt       DateTime @default(now())
  
  @@index([refundId])
  @@index([status])
  @@schema("school")
}

model CommunicationTemplate {
  id          String   @id @default(cuid())
  schoolId    String?  // null = global template, else school-specific override
  category    String   // 'email', 'sms', 'push'
  type        String   // 'welcome', 'fee_reminder', 'leave_approved', etc.
  key         String   // unique identifier like 'student_welcome_email'
  name        String   // human-readable name
  description String?
  
  // Template content
  subject     String?  // for emails
  htmlBody    String?  // email HTML template
  textBody    String?  // fallback plain text
  smsBody     String?  // for SMS (160 char optimized)
  
  // Styling
  designSystem String?  // 'modern', 'classic', 'minimal' - references design tokens
  primaryColor String?  // hex or variable name
  accentColor  String?
  
  // Variables schema (JSON) - for validation & UI
  variablesSchema String? // [{"name": "studentName", "type": "string", "required": true}]
  
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false) // fallback if school has no custom
  version     Int      @default(1)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([schoolId, key])
  @@index([schoolId, category, type])
  @@index([isDefault, isActive])
  @@schema("school")
}
