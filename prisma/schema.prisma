generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["saas", "school"]
}

model School {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  domain       String?       @unique
  email        String
  phone        String?
  address      String?
  city         String?
  state        String?
  pinCode      String?
  logo         String?
  isActive     Boolean       @default(true)
  isDemo       Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  subscription Subscription?
  customRoles  CustomRole[]
  students     Student[]
  teachers     Teacher[]
  User         school_User[]
  leaveTypes   LeaveType[]
  leaveSettings LeaveSettings[]
  leaveWorkflows LeaveWorkflow[]
  leaveBalances LeaveBalance[]
  leaveApplications LeaveApplication[]
  academicYears AcademicYear[]
  boards       Board[]
  mediums      Medium[]
  classes      Class[]
  sections     Section[]
  timings      SchoolTiming[]
  announcements Announcement[]
  medicalRecords MedicalRecord[]
  fineRules     FineRule[]
  messengerConversations MessengerConversation[]
  messengerMessages      MessengerMessage[]
  messengerParticipants  MessengerConversationParticipant[]
  messengerReadReceipts  MessengerMessageReadReceipt[]
  messengerReactions     MessengerMessageReaction[]

  @@index([slug])
  @@index([isActive])
  @@index([isDemo])
  @@schema("saas")
}

model Subscription {
  id                   String                @id @default(cuid())
  schoolId             String                @unique
  plan                 String                @default("trial")
  status               String                @default("trial")
  trialEndsAt          DateTime?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  maxStudents          Int                   @default(50)
  maxTeachers          Int                   @default(5)
  features             String                @default("[]")
  billingCycle         String                @default("monthly")
  price                Int                   @default(0)
  originalAmount       Int?
  discountAmount       Int                   @default(0)
  promoCodeId          String?
  billingEmail         String?
  paymentMethod        String?
  paymentId            String?
  autoRenew            Boolean               @default(false)
  cancelledAt          DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  razorpayOrderId      String?
  razorpayPaymentId    String?
  invoices             Invoice[]
  subscriptionPayments SubscriptionPayment[]
  school               School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  promoCodes           SubscriptionPromo[]
  promoCode            PromoCode?            @relation(fields: [promoCodeId], references: [id])

  @@index([plan])
  @@index([status])
  @@index([trialEndsAt])
  @@schema("saas")
}

model Invoice {
  id             String       @id @default(cuid())
  subscriptionId String
  amount         Float
  originalAmount Float?       // Original amount before discount
  discountAmount Float        @default(0) // Discount amount applied
  promoCodeId    String?      // Reference to applied promo code
  currency       String       @default("INR")
  status         String       @default("pending")
  description    String?
  paymentMethod  String?
  transactionId  String?
  paidAt         DateTime?
  dueDate        DateTime
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  promoCode      PromoCode?    @relation(fields: [promoCodeId], references: [id])

  @@index([subscriptionId])
  @@index([status])
  @@index([dueDate])
  @@index([promoCodeId])
  @@schema("saas")
}

model Plan {
  id           String   @id @default(cuid())
  name         String   @unique
  displayName  String
  description  String?
  priceMonthly Float    @default(0)
  priceYearly  Float    @default(0)
  currency     String   @default("INR")
  maxStudents  Int      @default(50)
  maxTeachers  Int      @default(5)
  features     String   @default("[]")
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  trialDays    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([name])
  @@index([isActive])
  @@schema("saas")
}

model CustomRole {
  id          String        @id @default(cuid())
  name        String
  description String?
  permissions String        @default("[]")
  schoolId    String?
  isDefault   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  school      School?       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  User        school_User[]
  leaveWorkflows LeaveWorkflow[]

  @@unique([name, schoolId])
  @@index([schoolId])
  @@schema("school")
}

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()"))
  email        String    @unique
  name         String
  password     String
  role         String    @default("super_admin")
  isActive     Boolean?  @default(true)
  isSuperAdmin Boolean?  @default(false)
  createdAt    DateTime? @default(now()) @db.Timestamp(6)
  updatedAt    DateTime? @default(now()) @updatedAt @db.Timestamp(6)

  @@index([email])
  @@index([role])
  @@schema("saas")
}

model VerificationToken {
  identifier String
  token      String    @unique
  expires    DateTime  @db.Timestamp(6)
  createdAt  DateTime? @default(now()) @db.Timestamp(6)
  updatedAt  DateTime? @default(now()) @db.Timestamp(6)

  @@unique([identifier, token])
  @@schema("saas")
}

model SaasSetting {
  id        String   @id @default(cuid())
  group     String
  key       String
  value     String   @default("")
  updatedAt DateTime @updatedAt

  @@unique([group, key])
  @@index([group])
  @@schema("saas")
}

model CronJobConfig {
  id          String    @id @default(cuid())
  jobName     String    @unique
  scope       String    // 'school' | 'saas'
  category    String    // 'communication' | 'billing' | 'analytics' | 'maintenance' | 'marketing'
  description String
  schedule    String
  enabled     Boolean   @default(true)
  lastRunAt   DateTime?
  lastStatus  String?   // 'success' | 'failed' | 'running'
  lastRunMs   Int?
  nextRunAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([scope])
  @@index([enabled])
  @@schema("saas")
  @@map("cron_job_configs")
}

model CronJobRun {
  id          String    @id @default(cuid())
  jobName     String
  scope       String    // 'school' | 'saas'
  status      String    // 'running' | 'success' | 'failed'
  triggeredBy String    @default("scheduler") // 'scheduler' | 'manual'
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  durationMs  Int?
  processed   Int?
  failed      Int?
  output      String?   @db.Text
  error       String?   @db.Text

  @@index([jobName])
  @@index([scope])
  @@index([status])
  @@index([startedAt])
  @@schema("saas")
  @@map("cron_job_runs")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorEmail String
  action     String
  target     String?
  targetName String?
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([actorEmail])
  @@index([action])
  @@index([createdAt])
  @@schema("saas")
}

model SaasAnnouncement {
  id          String    @id @default(cuid())
  title       String
  message     String
  type        String    @default("info")
  targetPlans String?
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive])
  @@index([createdAt])
  @@schema("saas")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
  @@schema("saas")
}

model Student {
  id                    String                 @id @default(cuid())
  admissionNo           String                 @unique
  name                  String
  email                 String?
  photo                 String?
  class                 String
  section               String
  rollNo                String
  gender                String
  dateOfBirth           String
  status                String                 @default("active")
  phone                 String?
  address               String?
  city                  String?
  state                 String?
  pinCode               String?
  nationality           String?
  religion              String?
  category              String?
  motherTongue          String?
  languageMedium        String?
  bloodGroup            String?
  aadharNumber          String?
  stsId                 String?
  board                 String?
  emergencyContact      String?
  emergencyRelation     String?
  medicalConditions     String?
  allergies             String?
  medications           String?
  doctorName            String?
  doctorPhone           String?
  transport             String?
  transportRoute        String?
  hostel                String?
  sibling               String?
  siblingName           String?
  siblingClass          String?
  parentName            String?
  parentPhone           String?
  parentEmail           String?
  fatherName            String?
  fatherOccupation      String?
  fatherPhone           String?
  fatherEmail           String?
  motherName            String?
  motherOccupation      String?
  motherPhone           String?
  motherEmail           String?
  guardianName          String?
  guardianRelation      String?
  guardianPhone         String?
  previousSchool        String?
  previousClass         String?
  previousSchoolName    String?
  previousSchoolAddress String?
  previousSchoolPhone   String?
  previousSchoolEmail   String?
  transferCertificate   String?
  transferCertificateNo String?
  bankName              String?
  bankAccountNumber     String?
  bankIfsc              String?
  documents             String?
  gpa                   Float                  @default(0)
  rank                  Int                    @default(0)
  disciplineScore       Int                    @default(100)
  incidents             Int                    @default(0)
  achievements          Int                    @default(0)
  remarks               String?
  admissionDate         String?
  enrollmentDate        String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  academicYear          String                 @default("2024-25")
  academicYearId        String?
  schoolId              String?
  contactPreference     String?
  employment            String?
  exitDate              String?
  exitReason            String?
  exitRemarks           String?
  higherEducation       String?
  mentorshipAreas       String?
  socialLinks           String?
  tcNumber              String?
  assignmentSubmissions AssignmentSubmission[]
  assignmentRecipients  AssignmentRecipient[]
  attendanceRecords     AttendanceRecord[]
  examResults           ExamResult[]
  arrears               FeeArrears[]
  feeRecords            FeeRecord[]
  fines                 Fine[]
  bookLoans             BookLoan[]
  attendanceFineCounters AttendanceFineCounter[]
  academicYearRef       AcademicYear?          @relation("StudentAcademicYear", fields: [academicYearId], references: [id])
  school                School?                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  promotions            StudentPromotion[]
  transportAssignments  StudentTransport[]
  medicalRecords        MedicalRecord[]
  razorpayTransactions  RazorpayPaymentTransaction[] @relation("RazorpayPaymentStudent")
  refunds               RefundRequest[]

  @@index([schoolId])
  @@index([class])
  @@index([status])
  @@index([gender])
  @@index([class, status])
  @@index([name])
  @@index([admissionNo])
  @@index([createdAt])
  @@index([parentName])
  @@index([academicYear])
  @@index([academicYearId])
  @@index([class, academicYear])
  @@index([status, academicYear])
  @@index([name, class])
  @@index([rollNo])
  @@index([email])
  @@index([schoolId, status])
  @@index([schoolId, name])
  @@index([schoolId, class])
  @@index([schoolId, admissionNo])
  @@index([schoolId, email])
  @@index([schoolId, rollNo])
  @@index([schoolId, status, name])
  @@index([schoolId, status, class])
  @@index([name, status])
  @@index([name, admissionNo])
  @@index([email, status])
  @@schema("school")
}

model MedicalRecord {
  id          String   @id @default(cuid())
  studentId   String
  date        DateTime @default(now())
  type        String
  title       String
  description String?
  doctor      String?
  status      String   @default("pending")
  notes       String?
  attachments String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  student     Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  school      School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolId    String
  
  @@index([studentId])
  @@index([date])
  @@index([type])
  @@index([status])
  @@index([schoolId])
  @@schema("school")
}

model Teacher {
  id                      String                   @id @default(cuid())
  employeeId              String                   @unique
  name                    String
  email                   String                   @unique
  phone                   String?
  gender                  String?
  dateOfBirth             String?
  subject                 String?
  qualification           String?
  experience              Int?                     @default(0)
  status                  String                   @default("active")
  address                 String?
  photo                   String?
  joiningDate             String?
  salary                  Float?
  department              String?
  designation             String?
  bloodGroup              String?
  aadharNumber            String?
  bankName                String?
  bankAccountNo           String?
  bankIfsc                String?
  emergencyName           String?
  emergencyPhone          String?
  remarks                 String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  userId                  String?                  @unique
  schoolId                String?
  classTeacherOf          String?
  isClassTeacher          Boolean                  @default(false)
  assignments             Assignment[]
  attendanceRecords       AttendanceRecord[]
  classTeacherAssignments ClassTeacherAssignment[]
  lessonPlans             LessonPlan[]
  school                  School?                  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user                    school_User?             @relation(fields: [userId], references: [id])
  leaveRequests           TeacherLeave[]
  notes                   TeacherNote[]
  schedules               TeacherSchedule[]
  leaveBalance            LeaveBalance[]
  leaveApplications       LeaveApplication[]
  approvedApplications    LeaveApplication[] @relation("LeaveApprover")
  approvalHistory         LeaveApprovalHistory[] @relation("LeaveApprovalApprover")

  @@index([schoolId])
  @@index([status])
  @@index([department])
  @@index([name])
  @@index([createdAt])
  @@index([isClassTeacher])
  @@index([schoolId, status])
  @@index([schoolId, name])
  @@index([schoolId, email])
  @@index([schoolId, employeeId])
  @@index([schoolId, subject])
  @@index([schoolId, designation])
  @@index([schoolId, department])
  @@index([schoolId, status, name])
  @@index([name, status])
  @@index([email, status])
  @@index([employeeId, status])
  @@index([subject, status])
  @@index([name, employeeId])
  @@index([name, subject])
  @@schema("school")
}

model ClassTeacherAssignment {
  id             String   @id @default(cuid())
  teacherId      String
  classId        String
  sectionId      String?
  boardId        String?
  mediumId       String?
  academicYearId String
  assignedDate   String
  isActive       Boolean  @default(true)
  schoolId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  teacher        Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, classId, sectionId, academicYearId])
  @@index([teacherId])
  @@index([classId])
  @@index([academicYearId])
  @@index([schoolId])
  @@schema("school")
}

model TeacherSchedule {
  id             String   @id @default(cuid())
  teacherId      String
  classId        String
  sectionId      String?
  subject        String
  dayOfWeek      String
  periodNumber   Int
  startTime      String
  endTime        String
  roomNumber     String?
  academicYearId String?
  isActive       Boolean  @default(true)
  schoolId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  teacher        Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, classId, dayOfWeek, periodNumber, academicYearId])
  @@index([teacherId])
  @@index([classId])
  @@index([dayOfWeek])
  @@index([academicYearId])
  @@index([schoolId])
  @@schema("school")
}

model LessonPlan {
  id             String   @id @default(cuid())
  teacherId      String
  title          String
  subject        String
  classId        String
  sectionId      String?
  date           String
  objectives     String?
  content        String?
  resources      String?
  activities     String?
  homework       String?
  notes          String?
  status         String   @default("draft")
  academicYearId String?
  schoolId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  teacher        Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([classId])
  @@index([date])
  @@index([status])
  @@index([schoolId])
  @@schema("school")
}

model Assignment {
  id             String                 @id @default(cuid())
  teacherId      String
  title          String
  description    String?
  subject        String
  classId        String
  sectionId      String?
  type           String                 @default("homework")
  dueDate        String
  totalMarks     Float                  @default(100)
  instructions   String?
  attachments    String?
  status         String                 @default("active")
  academicYearId String?
  schoolId       String?
  publishAt      DateTime?
  dueAt          DateTime?
  closeAt        DateTime?
  audienceType   String?
  gradingMode    String?
  latePolicy     String?
  visibilityScope String?
  publishedBy    String?
  isScheduled    Boolean                @default(false)
  templateId     String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  teacher        Teacher                @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  recipients     AssignmentRecipient[]
  activities     AssignmentActivity[]
  submissions    AssignmentSubmission[]

  @@index([teacherId])
  @@index([classId])
  @@index([dueDate])
  @@index([status])
  @@index([schoolId])
  @@index([schoolId, status, dueAt(sort: Desc)])
  @@index([schoolId, teacherId, createdAt(sort: Desc)])
  @@index([schoolId, classId, sectionId, dueAt(sort: Desc)])
  @@schema("school")
}

model AssignmentSubmission {
  id           String     @id @default(cuid())
  assignmentId String
  studentId    String
  submittedAt  String?
  content      String?
  attachments  String?
  marks        Float?
  grade        String?
  feedback     String?
  status       String     @default("pending")
  schoolId     String?
  submittedAtTs DateTime?
  attemptNo    Int        @default(1)
  submissionType String?
  storagePath  String?
  isLate       Boolean    @default(false)
  plagiarismScore Float?
  gradedBy     String?
  gradedAt     DateTime?
  score        Float?
  feedbackJson String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
  @@index([studentId])
  @@index([status])
  @@index([schoolId, assignmentId, submittedAtTs(sort: Desc)])
  @@index([schoolId, studentId, submittedAtTs(sort: Desc)])
  @@index([schoolId, status, submittedAtTs(sort: Desc)])
  @@schema("school")
}

model AssignmentRecipient {
  id              String     @id @default(cuid())
  schoolId        String?
  assignmentId    String
  studentId       String
  recipientStatus String     @default("assigned")
  dueAt           DateTime?
  publishedAt     DateTime?
  lastNotifiedAt  DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  assignment      Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student         Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
  @@index([studentId])
  @@index([schoolId, studentId, dueAt(sort: Desc)])
  @@index([schoolId, recipientStatus, dueAt(sort: Desc)])
  @@schema("school")
}

model AssignmentActivity {
  id            String     @id @default(cuid())
  schoolId      String?
  assignmentId  String
  actorUserId   String?
  actorTeacherId String?
  activityType  String
  metadata      String?
  occurredAt    DateTime   @default(now())
  createdAt     DateTime   @default(now())
  assignment    Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([assignmentId, occurredAt(sort: Desc)])
  @@index([schoolId, activityType, occurredAt(sort: Desc)])
  @@schema("school")
}

model TeacherLeave {
  id         String    @id @default(cuid())
  teacherId  String
  leaveType  String
  fromDate   String
  toDate     String
  days       Float
  reason     String?
  status     String    @default("pending")
  approvedBy String?
  approvedAt DateTime?
  remarks    String?
  schoolId   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  teacher    Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([status])
  @@index([fromDate])
  @@index([schoolId])
  @@schema("school")
}

model TeacherNote {
  id        String   @id @default(cuid())
  teacherId String
  studentId String?
  classId   String?
  title     String
  content   String
  type      String   @default("general")
  isPrivate Boolean  @default(false)
  schoolId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([studentId])
  @@index([classId])
  @@index([schoolId])
  @@schema("school")
}

model FeeStructure {
  id                   String        @id @default(cuid())
  name                 String
  category             String
  amount               Float
  frequency            String
  dueDate              Int           @default(1)
  lateFee              Float         @default(0)
  description          String?
  applicableCategories String        @default("all")
  isActive             Boolean       @default(true)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  academicYearId       String?
  boardId              String?
  classId              String?
  mediumId             String?
  schoolId             String?
  feeRecords           FeeRecord[]
  academicYear         AcademicYear? @relation(fields: [academicYearId], references: [id])
  board                Board?        @relation(fields: [boardId], references: [id])
  class                Class?        @relation(fields: [classId], references: [id])
  medium               Medium?       @relation(fields: [mediumId], references: [id])

  @@index([schoolId])
  @@index([academicYearId])
  @@index([boardId])
  @@index([mediumId])
  @@index([classId])
  @@index([isActive])
  @@index([academicYearId, boardId, mediumId, classId])
  @@schema("school")
}

model FeeRecord {
  id             String       @id @default(cuid())
  studentId      String
  feeStructureId String
  amount         Float
  paidAmount     Float        @default(0)
  pendingAmount  Float
  discount       Float        @default(0)
  dueDate        String
  paidDate       String?
  status         String       @default("pending")
  paymentMethod  String?
  transactionId  String?
  receiptNumber  String?      @unique
  collectedBy    String?
  academicYear   String       @default("2024-25")
  remarks        String?
  refundAmount   Float        @default(0)  // Total refunded amount
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id])
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payments       Payment[]
  razorpayTransactions RazorpayPaymentTransaction[] @relation("RazorpayPaymentFeeRecord")

  @@index([studentId])
  @@index([status])
  @@index([academicYear])
  @@index([dueDate])
  @@index([studentId, status])
  @@index([studentId, academicYear])
  @@index([status, academicYear])
  @@index([dueDate, status])
  @@index([createdAt])
  @@index([paymentMethod])
  @@index([refundAmount])
  @@schema("school")
}

model Payment {
  id            String    @id @default(cuid())
  feeRecordId   String
  amount        Float
  paymentMethod String
  transactionId String?
  receiptNumber String    @unique
  paymentDate   String
  collectedBy   String?
  remarks       String?
  refundId      String?   // Link to refund if this payment was refunded
  refundAmount  Float?    // Amount refunded from this payment
  createdAt     DateTime  @default(now())
  feeRecord     FeeRecord @relation(fields: [feeRecordId], references: [id], onDelete: Cascade)

