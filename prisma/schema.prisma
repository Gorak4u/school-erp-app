  user              school_User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([schoolId, userId])
  @@index([schoolId, conversationId])
  @@index([schoolId, status])
  @@schema("school")
}

model MessengerMessage {
  id                String   @id @default(cuid())
  schoolId          String
  conversationId    String
  senderId          String
  messageType       String   @default("text")
  body              String   @db.Text
  attachments       Json?
  replyToId         String?
