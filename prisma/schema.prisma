generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model School {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  domain       String?       @unique
  email        String
  phone        String?
  address      String?
  city         String?
  state        String?
  pinCode      String?
  logo         String?
  isActive     Boolean       @default(true)
  isDemo       Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  customRoles  CustomRole[]
  students     Student[]
  subscription Subscription?
  teachers     Teacher[]
  users        User[]

  @@index([slug])
  @@index([isActive])
  @@index([isDemo])
}

model Subscription {
  id                 String    @id @default(cuid())
  schoolId           String    @unique
  plan               String    @default("trial")
  status             String    @default("trial")
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  maxStudents        Int       @default(50)
  maxTeachers        Int       @default(5)
  features           String    @default("[]")
  billingEmail       String?
  paymentMethod      String?
  paymentId          String?
  cancelledAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  razorpayOrderId    String?
  razorpayPaymentId  String?
  invoices           Invoice[]
  subscriptionPayments SubscriptionPayment[]
  school             School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([plan])
  @@index([status])
  @@index([trialEndsAt])
}

model Invoice {
  id             String       @id @default(cuid())
  subscriptionId String
  amount         Float
  currency       String       @default("INR")
  status         String       @default("pending")
  description    String?
  paymentMethod  String?
  transactionId  String?
  paidAt         DateTime?
  dueDate        DateTime
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([status])
  @@index([dueDate])
}

model Plan {
  id           String   @id @default(cuid())
  name         String   @unique
  displayName  String
  description  String?
  priceMonthly Float    @default(0)
  priceYearly  Float    @default(0)
  currency     String   @default("INR")
  maxStudents  Int      @default(50)
  maxTeachers  Int      @default(5)
  features     String   @default("[]")
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  trialDays    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([name])
  @@index([isActive])
}

model CustomRole {
  id          String   @id @default(cuid())
  name        String
  description String?
  permissions String   @default("[]")
  schoolId    String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  users       User[]

  @@unique([name, schoolId])
  @@index([schoolId])
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  password     String
  firstName    String
  lastName     String
  role         String      @default("admin")
  avatar       String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  schoolId     String?
  customRoleId String?
  accounts     Account[]
  sessions     Session[]
  teacher      Teacher?
  customRole   CustomRole? @relation(fields: [customRoleId], references: [id])
  school       School?     @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([customRoleId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SaasSetting {
  id        String   @id @default(cuid())
  group     String
  key       String
  value     String   @default("")
  updatedAt DateTime @updatedAt

  @@unique([group, key])
  @@index([group])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorEmail String
  action     String
  target     String?
  targetName String?
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([actorEmail])
  @@index([action])
  @@index([createdAt])
}

model SaasAnnouncement {
  id          String    @id @default(cuid())
  title       String
  message     String
  type        String    @default("info")
  targetPlans String?
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive])
  @@index([createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

model Student {
  id                    String             @id @default(cuid())
  admissionNo           String             @unique
  name                  String
  email                 String?
  photo                 String?
  class                 String
  section               String
  rollNo                String
  gender                String
  dateOfBirth           String
  status                String             @default("active")
  phone                 String?
  address               String?
  city                  String?
  state                 String?
  pinCode               String?
  nationality           String?
  religion              String?
  category              String?
  motherTongue          String?
  languageMedium        String?
  bloodGroup            String?
  aadharNumber          String?
  stsId                 String?
  board                 String?
  emergencyContact      String?
  emergencyRelation     String?
  medicalConditions     String?
  allergies             String?
  medications           String?
  doctorName            String?
  doctorPhone           String?
  transport             String?
  transportRoute        String?
  hostel                String?
  sibling               String?
  siblingName           String?
  siblingClass          String?
  parentName            String?
  parentPhone           String?
  parentEmail           String?
  fatherName            String?
  fatherOccupation      String?
  fatherPhone           String?
  fatherEmail           String?
  motherName            String?
  motherOccupation      String?
  motherPhone           String?
  motherEmail           String?
  guardianName          String?
  guardianRelation      String?
  guardianPhone         String?
  previousSchool        String?
  previousClass         String?
  previousSchoolName    String?
  previousSchoolAddress String?
  previousSchoolPhone   String?
  previousSchoolEmail   String?
  transferCertificate   String?
  transferCertificateNo String?
  bankName              String?
  bankAccountNumber     String?
  bankIfsc              String?
  documents             String?
  gpa                   Float              @default(0)
  rank                  Int                @default(0)
  disciplineScore       Int                @default(100)
  incidents             Int                @default(0)
  achievements          Int                @default(0)
  remarks               String?
  admissionDate         String?
  enrollmentDate        String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  academicYear          String             @default("2024-25")
  schoolId              String?
  attendanceRecords     AttendanceRecord[]
  examResults           ExamResult[]
  feeRecords            FeeRecord[]
  school                School?            @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([class])
  @@index([status])
  @@index([gender])
  @@index([class, status])
  @@index([name])
  @@index([admissionNo])
  @@index([createdAt])
  @@index([parentName])
  @@index([academicYear])
}

model Teacher {
  id                String             @id @default(cuid())
  employeeId        String             @unique
  name              String
  email             String             @unique
  phone             String?
  gender            String?
  dateOfBirth       String?
  subject           String?
  qualification     String?
  experience        Int?               @default(0)
  status            String             @default("active")
  address           String?
  photo             String?
  joiningDate       String?
  salary            Float?
  department        String?
  designation       String?
  bloodGroup        String?
  aadharNumber      String?
  bankName          String?
  bankAccountNo     String?
  bankIfsc          String?
  emergencyName     String?
  emergencyPhone    String?
  remarks           String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  userId            String?            @unique
  schoolId          String?
  attendanceRecords AttendanceRecord[]
  school            School?            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user              User?              @relation(fields: [userId], references: [id])

  @@index([schoolId])
  @@index([status])
  @@index([department])
  @@index([name])
  @@index([createdAt])
}

model FeeStructure {
  id                   String        @id @default(cuid())
  name                 String
  category             String
  amount               Float
  frequency            String
  dueDate              Int           @default(1)
  lateFee              Float         @default(0)
  description          String?
  applicableCategories String        @default("all")
  isActive             Boolean       @default(true)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  academicYearId       String?
  boardId              String?
  classId              String?
  mediumId             String?
  schoolId             String?
  feeRecords           FeeRecord[]
  academicYear         AcademicYear? @relation(fields: [academicYearId], references: [id])
  board                Board?        @relation(fields: [boardId], references: [id])
  class                Class?        @relation(fields: [classId], references: [id])
  medium               Medium?       @relation(fields: [mediumId], references: [id])

  @@index([schoolId])
  @@index([academicYearId])
  @@index([boardId])
  @@index([mediumId])
  @@index([classId])
  @@index([isActive])
  @@index([academicYearId, boardId, mediumId, classId])
}

model FeeRecord {
  id             String       @id @default(cuid())
  studentId      String
  feeStructureId String
  amount         Float
  paidAmount     Float        @default(0)
  pendingAmount  Float
  discount       Float        @default(0)
  dueDate        String
  paidDate       String?
  status         String       @default("pending")
  paymentMethod  String?
  transactionId  String?
  receiptNumber  String?      @unique
  collectedBy    String?
  academicYear   String       @default("2024-25")
  remarks        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id])
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payments       Payment[]

  @@index([studentId])
  @@index([status])
  @@index([academicYear])
  @@index([dueDate])
  @@index([studentId, status])
  @@index([createdAt])
}

model Payment {
  id            String    @id @default(cuid())
  feeRecordId   String
  amount        Float
  paymentMethod String
  transactionId String?
  receiptNumber String    @unique
  paymentDate   String
  collectedBy   String?
  remarks       String?
  createdAt     DateTime  @default(now())
  feeRecord     FeeRecord @relation(fields: [feeRecordId], references: [id], onDelete: Cascade)
}

model SubscriptionPayment {
  id            String   @id @default(cuid())
  subscriptionId String
  orderId       String
  paymentId     String?
  amount        Float
  currency      String   @default("INR")
  status        String   @default("pending")
  paymentMethod String   @default("razorpay")
  receiptNumber String
  paymentDate   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([orderId])
  @@index([paymentId])
}

model Discount {
  id                   String   @id @default(cuid())
  name                 String
  type                 String
  value                Float
  applicableClasses    String
  applicableCategories String
  maxDiscountAmount    Float?
  isActive             Boolean  @default(true)
  validFrom            String
  validTo              String
  description          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  schoolId             String?

  @@index([schoolId])
}

model AttendanceRecord {
  id        String   @id @default(cuid())
  studentId String
  teacherId String?
  date      String
  status    String
  subject   String?
  class     String?
  section   String?
  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher   Teacher? @relation(fields: [teacherId], references: [id])

  @@unique([studentId, date, subject])
  @@index([date])
  @@index([class])
  @@index([studentId])
  @@index([class, date])
  @@index([status])
}

model Exam {
  id           String       @id @default(cuid())
  name         String
  type         String
  class        String
  section      String?
  subject      String
  date         String
  duration     Int
  totalMarks   Float
  passingMarks Float
  academicYear String       @default("2024-25")
  status       String       @default("scheduled")
  venue        String?
  instructions String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  schoolId     String?
  results      ExamResult[]

  @@index([schoolId])
  @@index([class])
  @@index([status])
  @@index([academicYear])
  @@index([date])
  @@index([class, academicYear])
}

model ExamResult {
  id            String   @id @default(cuid())
  examId        String
  studentId     String
  marksObtained Float
  grade         String?
  remarks       String?
  isAbsent      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  content     String
  type        String    @default("general")
  targetRoles String
  isActive    Boolean   @default(true)
  publishedAt DateTime  @default(now())
  expiresAt   DateTime?
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AcademicYear {
  id            String         @id @default(cuid())
  year          String         @unique
  name          String
  startDate     String
  endDate       String
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  classes       Class[]
  sections      Section[]
  feeStructures FeeStructure[]
  mediums       Medium[]

  @@index([year])
  @@index([isActive])
}

model Medium {
  id             String         @id @default(cuid())
  code           String         @unique
  name           String
  description    String?
  isActive       Boolean        @default(true)
  academicYearId String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  classes        Class[]
  feeStructures  FeeStructure[]
  academicYear   AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([isActive])
  @@index([academicYearId])
}

model Class {
  id             String         @id @default(cuid())
  code           String         @unique
  name           String
  level          String
  mediumId       String
  academicYearId String
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  academicYear   AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  medium         Medium         @relation(fields: [mediumId], references: [id], onDelete: Cascade)
  feeStructures  FeeStructure[]
  sections       Section[]

  @@index([code])
  @@index([level])
  @@index([isActive])
  @@index([mediumId])
  @@index([academicYearId])
}

model Section {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  classId        String
  academicYearId String
  capacity       Int
  roomNumber     String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  class          Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([isActive])
  @@index([classId])
  @@index([academicYearId])
}

model SchoolSetting {
  id        String   @id @default(cuid())
  group     String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([group, key])
  @@index([group])
}

model Board {
  id            String         @id @default(cuid())
  code          String         @unique
  name          String
  description   String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  feeStructures FeeStructure[]

  @@index([code])
  @@index([isActive])
}

model SchoolTiming {
  id        String   @id @default(cuid())
  name      String
  type      String
  startTime String
  endTime   String
  dayOfWeek String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([dayOfWeek])
  @@index([sortOrder])
}
