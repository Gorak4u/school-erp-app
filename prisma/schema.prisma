  sourceType      String
  sourceId        String?
  issuedAt        DateTime @default(now())
  dueDate         DateTime
  paidAt          DateTime?
  waivedAt        DateTime?
  waivedBy        String?
  waiverReason    String?
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  rule            FineRule? @relation(fields: [ruleId], references: [id])
  payments        FinePayment[]
  waiverRequests  FineWaiverRequest[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@index([schoolId, studentId])
  @@index([status, dueDate])
  @@index([type, status])
  @@index([schoolId, status])
  @@index([schoolId, type])
  @@index([sourceType, sourceId])
  @@index([schoolId, createdAt]) // For pagination and sorting
  @@index([studentId, status]) // For student-specific queries
  @@index([fineNumber]) // For fine number searches
