  schoolId    String
  messageId   String
  userId      String
  readAt      DateTime @default(now())

  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  message     MessengerMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user        school_User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([schoolId, userId])
  @@index([schoolId, messageId])
  @@schema("school")
}

model MessengerMessageReaction {
  id          String   @id @default(cuid())
  schoolId    String
  messageId   String
  userId      String
  reaction    String
  createdAt   DateTime @default(now())

  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  message     MessengerMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user        school_User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, reaction])
  @@index([schoolId, messageId])
  @@index([schoolId, userId])
  @@schema("school")
}

