// ========================================
// Razorpay Payment Integration Models
// ========================================

// Razorpay Payment Orders - Links to your existing FeeRecord
model RazorpayPaymentOrder {
  id          String   @id @db.VarChar(255) // Razorpay order ID
  amount      Decimal  @db.Decimal(10, 2)
  currency    String   @default("INR") @db.VarChar(3)
  receipt     String   @db.VarChar(255)
  status      String   @default("created") @db.VarChar(50) // created, paid, failed, expired
  notes       Json?    // Student info, fee IDs, metadata
  createdBy   String   @db.VarChar(255) @map("created_by") // Links to school_User.email
  schoolId    String?  @db.VarChar(255) @map("school_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  transactions RazorpayPaymentTransaction[]

  @@map("razorpay_payment_orders")
  @@index([status])
  @@index([createdBy])
  @@index([schoolId])
  @@index([createdAt])
  @@index([receipt])
  @@schema("school")
}

// Razorpay Payment Transactions - Links to your existing Payment model
model RazorpayPaymentTransaction {
  id             String    @id @db.VarChar(255) // Razorpay payment ID
  orderId        String    @db.VarChar(255) @map("order_id")
  amount         Decimal   @db.Decimal(10, 2)
  currency       String    @default("INR") @db.VarChar(3)
  status         String    @default("pending") @db.VarChar(50) // pending, verified, failed
  gatewayResponse Json?    @map("gateway_response") // Full Razorpay response
  verifiedAt     DateTime? @map("verified_at") // When payment was verified
  feeRecordIds   Json?     @map("fee_record_ids") // Array of FeeRecord IDs (your existing model)
  studentId      String?   @db.VarChar(255) @map("student_id") // Links to Student.id
  paymentMethod  String?   @db.VarChar(50) @map("payment_method") // razorpay, upi, cash, etc.
  collectedBy    String?   @db.VarChar(255) @map("collected_by") // Links to school_User.email
  remarks        String?   @db.Text // Payment remarks
  schoolId       String?   @db.VarChar(255) @map("school_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations
  order         RazorpayPaymentOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Links to your existing models
  student       Student?  @relation("RazorpayPaymentStudent", fields: [studentId], references: [id])
  feeRecords    FeeRecord[] @relation("RazorpayPaymentFeeRecord")

  @@map("razorpay_payment_transactions")
  @@index([orderId])
  @@index([status])
  @@index([studentId])
  @@index([paymentMethod])
  @@index([schoolId])
  @@index([createdAt])
  @@index([verifiedAt])
  @@schema("school")
}

// Razorpay Webhook Events
model RazorpayWebhookEvent {
  id              BigInt   @id @default(autoincrement())
  eventId         String   @db.VarChar(255) @map("event_id") // Razorpay event ID
  eventType       String   @db.VarChar(100) @map("event_type") // payment.captured, payment.failed, etc.
  paymentId       String?  @db.VarChar(255) @map("payment_id") // Associated payment ID
  orderId         String?  @db.VarChar(255) @map("order_id") // Associated order ID
  payload         Json     // Full webhook payload
  processed       Boolean  @default(false) // Whether webhook was processed
  processingError String?  @db.Text @map("processing_error") // Any processing errors
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("razorpay_webhook_events")
  @@index([eventId])
  @@index([eventType])
  @@index([paymentId])
  @@index([orderId])
  @@index([processed])
  @@index([createdAt])
  @@schema("school")
}

// Razorpay Audit Log
model RazorpayAuditLog {
  id         BigInt   @id @default(autoincrement())
  action     String   @db.VarChar(100) // order_created, payment_verified, etc.
  entityType String   @db.VarChar(50) @map("entity_type") // order, transaction, webhook
  entityId   String   @db.VarChar(255) @map("entity_id") // ID of the entity
  oldValues  Json?    @map("old_values") // Previous state (for updates)
  newValues  Json?    @map("new_values") // New state
  userId     String?  @db.VarChar(255) @map("user_id") // User who performed action
  userEmail  String?  @db.VarChar(255) @map("user_email") // User email
  ipAddress  String?  @db.VarChar(45) @map("ip_address") // Client IP
  userAgent  String?  @db.Text @map("user_agent") // Client user agent
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("razorpay_audit_log")
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([userId])
  @@index([userEmail])
  @@index([createdAt])
  @@schema("school")
}

// Promo Code System for Subscription Discounts
model PromoCode {
  id                String    @id @default(cuid())
  code              String    @unique
  description       String?
  discountType      String    // "percentage" or "fixed"
  discountValue     Float     // e.g., 20.0 for 20% or ₹2000
  maxDiscountAmount Float?    // Cap for percentage discounts
  applicablePlans   String    // JSON array: ["basic", "professional"] or "all"
  usageLimit        Int?      // Max times usable across all users
  usageCount        Int       @default(0) // Current usage count
  validFrom         DateTime
  validTo           DateTime
  isActive          Boolean   @default(true)
  createdBy         String    // Super admin email
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  subscriptionPromos SubscriptionPromo[]
  invoices           Invoice[]
  subscriptions       Subscription[]

  @@index([code])
  @@index([isActive])
  @@index([validFrom])
  @@index([validTo])
  @@schema("saas")
}

model SubscriptionPromo {
  id             String    @id @default(cuid())
  subscriptionId String
  promoCodeId    String
  discountAmount Float     // Actual discount amount applied
  appliedAt      DateTime  @default(now())

  // Relations
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  promoCode      PromoCode    @relation(fields: [promoCodeId], references: [id])

  @@unique([subscriptionId, promoCodeId]) // One promo per subscription
  @@schema("saas")
}

// ========================================
// Fine Management System Models
// ========================================

// Fine Rule Templates - Configurable by school
model FineRule {
  id              String   @id @default(cuid())
  schoolId        String
  name            String
  code            String
  type            String
  baseAmount      Float
  dailyRate       Float?
  maxAmount       Float?
  percentageOf    String?
  graceDays       Int      @default(0)
  triggerEvent    String
  applicableTo    String
  classIds        String?
  categoryIds     String?
  autoApply       Boolean  @default(false)
  autoNotify      Boolean  @default(true)
  requiresApproval Boolean @default(false)
  academicYearId  String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
