generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["saas", "school"]
}

model School {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  domain       String?       @unique
  email        String
  phone        String?
  address      String?
  city         String?
  state        String?
  pinCode      String?
  logo         String?
  isActive     Boolean       @default(true)
  isDemo       Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  subscription Subscription?
  customRoles  CustomRole[]
  students     Student[]
  teachers     Teacher[]
  User         school_User[]
  leaveTypes   LeaveType[]
  leaveSettings LeaveSettings[]
  leaveWorkflows LeaveWorkflow[]
  leaveBalances LeaveBalance[]
  leaveApplications LeaveApplication[]
  academicYears AcademicYear[]
  boards       Board[]
  mediums      Medium[]
  classes      Class[]
  sections     Section[]
  timings      SchoolTiming[]
  announcements Announcement[]

  @@index([slug])
  @@index([isActive])
  @@index([isDemo])
  @@schema("saas")
}

model Subscription {
  id                   String                @id @default(cuid())
  schoolId             String                @unique
  plan                 String                @default("trial")
  status               String                @default("trial")
  trialEndsAt          DateTime?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  maxStudents          Int                   @default(50)
  maxTeachers          Int                   @default(5)
  features             String                @default("[]")
  billingCycle         String                @default("monthly")
  price                Int                   @default(0)
  billingEmail         String?
  paymentMethod        String?
  paymentId            String?
  autoRenew            Boolean               @default(false)
  cancelledAt          DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  razorpayOrderId      String?
  razorpayPaymentId    String?
  invoices             Invoice[]
  school               School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subscriptionPayments SubscriptionPayment[]

  @@index([plan])
  @@index([status])
  @@index([trialEndsAt])
  @@schema("saas")
}

model Invoice {
  id             String       @id @default(cuid())
  subscriptionId String
  amount         Float
  currency       String       @default("INR")
  status         String       @default("pending")
  description    String?
  paymentMethod  String?
  transactionId  String?
  paidAt         DateTime?
  dueDate        DateTime
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([status])
  @@index([dueDate])
  @@schema("saas")
}

model Plan {
  id           String   @id @default(cuid())
  name         String   @unique
  displayName  String
  description  String?
  priceMonthly Float    @default(0)
  priceYearly  Float    @default(0)
  currency     String   @default("INR")
  maxStudents  Int      @default(50)
  maxTeachers  Int      @default(5)
  features     String   @default("[]")
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  trialDays    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([name])
  @@index([isActive])
  @@schema("saas")
}

model CustomRole {
  id          String        @id @default(cuid())
  name        String
  description String?
  permissions String        @default("[]")
  schoolId    String?
  isDefault   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  school      School?       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  User        school_User[]
  leaveWorkflows LeaveWorkflow[]

  @@unique([name, schoolId])
  @@index([schoolId])
  @@schema("school")
}

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()"))
  email        String    @unique
  name         String
  password     String
  role         String    @default("super_admin")
  isActive     Boolean?  @default(true)
  isSuperAdmin Boolean?  @default(false)
  createdAt    DateTime? @default(now()) @db.Timestamp(6)
  updatedAt    DateTime? @default(now()) @updatedAt @db.Timestamp(6)

  @@index([email])
  @@index([role])
  @@schema("saas")
}

model VerificationToken {
  identifier String
  token      String    @unique
  expires    DateTime  @db.Timestamp(6)
  createdAt  DateTime? @default(now()) @db.Timestamp(6)
  updatedAt  DateTime? @default(now()) @db.Timestamp(6)

  @@unique([identifier, token])
  @@schema("saas")
}

model SaasSetting {
  id        String   @id @default(cuid())
  group     String
  key       String
  value     String   @default("")
  updatedAt DateTime @updatedAt

  @@unique([group, key])
  @@index([group])
  @@schema("saas")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorEmail String
  action     String
  target     String?
  targetName String?
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([actorEmail])
  @@index([action])
  @@index([createdAt])
  @@schema("saas")
}

model SaasAnnouncement {
  id          String    @id @default(cuid())
  title       String
  message     String
  type        String    @default("info")
  targetPlans String?
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive])
  @@index([createdAt])
  @@schema("saas")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
  @@schema("saas")
}

model Student {
  id                    String                 @id @default(cuid())
  admissionNo           String                 @unique
  name                  String
  email                 String?
  photo                 String?
  class                 String
  section               String
  rollNo                String
  gender                String
  dateOfBirth           String
  status                String                 @default("active")
  phone                 String?
  address               String?
  city                  String?
  state                 String?
  pinCode               String?
  nationality           String?
  religion              String?
  category              String?
  motherTongue          String?
  languageMedium        String?
  bloodGroup            String?
  aadharNumber          String?
  stsId                 String?
  board                 String?
  emergencyContact      String?
  emergencyRelation     String?
  medicalConditions     String?
  allergies             String?
  medications           String?
  doctorName            String?
  doctorPhone           String?
  transport             String?
  transportRoute        String?
  hostel                String?
  sibling               String?
  siblingName           String?
  siblingClass          String?
  parentName            String?
  parentPhone           String?
  parentEmail           String?
  fatherName            String?
  fatherOccupation      String?
  fatherPhone           String?
  fatherEmail           String?
  motherName            String?
  motherOccupation      String?
  motherPhone           String?
  motherEmail           String?
  guardianName          String?
  guardianRelation      String?
  guardianPhone         String?
  previousSchool        String?
  previousClass         String?
  previousSchoolName    String?
  previousSchoolAddress String?
  previousSchoolPhone   String?
  previousSchoolEmail   String?
  transferCertificate   String?
  transferCertificateNo String?
  bankName              String?
  bankAccountNumber     String?
  bankIfsc              String?
  documents             String?
  gpa                   Float                  @default(0)
  rank                  Int                    @default(0)
  disciplineScore       Int                    @default(100)
  incidents             Int                    @default(0)
  achievements          Int                    @default(0)
  remarks               String?
  admissionDate         String?
  enrollmentDate        String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  academicYear          String                 @default("2024-25")
  academicYearId        String?
  schoolId              String?
  contactPreference     String?
  employment            String?
  exitDate              String?
  exitReason            String?
  exitRemarks           String?
  higherEducation       String?
  mentorshipAreas       String?
  socialLinks           String?
  tcNumber              String?
  assignmentSubmissions AssignmentSubmission[]
  attendanceRecords     AttendanceRecord[]
  examResults           ExamResult[]
  arrears               FeeArrears[]
  feeRecords            FeeRecord[]
  academicYearRef       AcademicYear?          @relation("StudentAcademicYear", fields: [academicYearId], references: [id])
  school                School?                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  promotions            StudentPromotion[]
  transportAssignments  StudentTransport[]

  @@index([schoolId])
  @@index([class])
  @@index([status])
  @@index([gender])
  @@index([class, status])
  @@index([name])
  @@index([admissionNo])
  @@index([createdAt])
  @@index([parentName])
  @@index([academicYear])
  @@index([academicYearId])
  @@index([class, academicYear])
  @@index([status, academicYear])
  @@index([name, class])
  @@index([rollNo])
  @@index([email])
  @@schema("school")
}

model Teacher {
  id                      String                   @id @default(cuid())
  employeeId              String                   @unique
  name                    String
  email                   String                   @unique
  phone                   String?
  gender                  String?
  dateOfBirth             String?
  subject                 String?
  qualification           String?
  experience              Int?                     @default(0)
  status                  String                   @default("active")
  address                 String?
  photo                   String?
  joiningDate             String?
  salary                  Float?
  department              String?
  designation             String?
  bloodGroup              String?
  aadharNumber            String?
  bankName                String?
  bankAccountNo           String?
  bankIfsc                String?
  emergencyName           String?
  emergencyPhone          String?
  remarks                 String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  userId                  String?                  @unique
  schoolId                String?
  classTeacherOf          String?
  isClassTeacher          Boolean                  @default(false)
  assignments             Assignment[]
  attendanceRecords       AttendanceRecord[]
  classTeacherAssignments ClassTeacherAssignment[]
  lessonPlans             LessonPlan[]
  school                  School?                  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user                    school_User?             @relation(fields: [userId], references: [id])
  leaveRequests           TeacherLeave[]
  notes                   TeacherNote[]
  schedules               TeacherSchedule[]
  leaveBalance            LeaveBalance[]
  leaveApplications       LeaveApplication[]
  approvedApplications    LeaveApplication[] @relation("LeaveApprover")
  approvalHistory         LeaveApprovalHistory[] @relation("LeaveApprovalApprover")

  @@index([schoolId])
  @@index([status])
  @@index([department])
  @@index([name])
  @@index([createdAt])
  @@index([isClassTeacher])
  @@schema("school")
}

model ClassTeacherAssignment {
  id             String   @id @default(cuid())
  teacherId      String
  classId        String
  sectionId      String?
  boardId        String?
  mediumId       String?
  academicYearId String
  assignedDate   String
  isActive       Boolean  @default(true)
  schoolId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  teacher        Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, classId, sectionId, academicYearId])
  @@index([teacherId])
  @@index([classId])
  @@index([academicYearId])
  @@index([schoolId])
  @@schema("school")
}

model TeacherSchedule {
  id             String   @id @default(cuid())
  teacherId      String
  classId        String
  sectionId      String?
  subject        String
  dayOfWeek      String
  periodNumber   Int
  startTime      String
  endTime        String
  roomNumber     String?
  academicYearId String?
  isActive       Boolean  @default(true)
  schoolId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  teacher        Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, classId, dayOfWeek, periodNumber, academicYearId])
  @@index([teacherId])
  @@index([classId])
  @@index([dayOfWeek])
  @@index([academicYearId])
  @@index([schoolId])
  @@schema("school")
}

model LessonPlan {
  id             String   @id @default(cuid())
  teacherId      String
  title          String
  subject        String
  classId        String
  sectionId      String?
  date           String
  objectives     String?
  content        String?
  resources      String?
  activities     String?
  homework       String?
  notes          String?
  status         String   @default("draft")
  academicYearId String?
  schoolId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  teacher        Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([classId])
  @@index([date])
  @@index([status])
  @@index([schoolId])
  @@schema("school")
}

model Assignment {
  id             String                 @id @default(cuid())
  teacherId      String
  title          String
  description    String?
  subject        String
  classId        String
  sectionId      String?
  type           String                 @default("homework")
  dueDate        String
  totalMarks     Float                  @default(100)
  instructions   String?
  attachments    String?
  status         String                 @default("active")
  academicYearId String?
  schoolId       String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  teacher        Teacher                @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  submissions    AssignmentSubmission[]

  @@index([teacherId])
  @@index([classId])
  @@index([dueDate])
  @@index([status])
  @@index([schoolId])
  @@schema("school")
}

model AssignmentSubmission {
  id           String     @id @default(cuid())
  assignmentId String
  studentId    String
  submittedAt  String?
  content      String?
  attachments  String?
  marks        Float?
  grade        String?
  feedback     String?
  status       String     @default("pending")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
  @@index([studentId])
  @@index([status])
  @@schema("school")
}

model TeacherLeave {
  id         String    @id @default(cuid())
  teacherId  String
  leaveType  String
  fromDate   String
  toDate     String
  days       Float
  reason     String?
  status     String    @default("pending")
  approvedBy String?
  approvedAt DateTime?
  remarks    String?
  schoolId   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  teacher    Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([status])
  @@index([fromDate])
  @@index([schoolId])
  @@schema("school")
}

model TeacherNote {
  id        String   @id @default(cuid())
  teacherId String
  studentId String?
  classId   String?
  title     String
  content   String
  type      String   @default("general")
  isPrivate Boolean  @default(false)
  schoolId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([studentId])
  @@index([classId])
  @@index([schoolId])
  @@schema("school")
}

model FeeStructure {
  id                   String        @id @default(cuid())
  name                 String
  category             String
  amount               Float
  frequency            String
  dueDate              Int           @default(1)
  lateFee              Float         @default(0)
  description          String?
  applicableCategories String        @default("all")
  isActive             Boolean       @default(true)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  academicYearId       String?
  boardId              String?
  classId              String?
  mediumId             String?
  schoolId             String?
  feeRecords           FeeRecord[]
  academicYear         AcademicYear? @relation(fields: [academicYearId], references: [id])
  board                Board?        @relation(fields: [boardId], references: [id])
  class                Class?        @relation(fields: [classId], references: [id])
  medium               Medium?       @relation(fields: [mediumId], references: [id])

  @@index([schoolId])
  @@index([academicYearId])
  @@index([boardId])
  @@index([mediumId])
  @@index([classId])
  @@index([isActive])
  @@index([academicYearId, boardId, mediumId, classId])
  @@schema("school")
}

model FeeRecord {
  id             String       @id @default(cuid())
  studentId      String
  feeStructureId String
  amount         Float
  paidAmount     Float        @default(0)
  pendingAmount  Float
  discount       Float        @default(0)
  dueDate        String
  paidDate       String?
  status         String       @default("pending")
  paymentMethod  String?
  transactionId  String?
  receiptNumber  String?      @unique
  collectedBy    String?
  academicYear   String       @default("2024-25")
  remarks        String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id])
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payments       Payment[]

  @@index([studentId])
  @@index([status])
  @@index([academicYear])
  @@index([dueDate])
  @@index([studentId, status])
  @@index([studentId, academicYear])
  @@index([status, academicYear])
  @@index([dueDate, status])
  @@index([createdAt])
  @@index([paymentMethod])
  @@schema("school")
}

model Payment {
  id            String    @id @default(cuid())
  feeRecordId   String
  amount        Float
  paymentMethod String
  transactionId String?
  receiptNumber String    @unique
  paymentDate   String
  collectedBy   String?
  remarks       String?
  createdAt     DateTime  @default(now())
  feeRecord     FeeRecord @relation(fields: [feeRecordId], references: [id], onDelete: Cascade)

  @@index([paymentDate])
  @@index([collectedBy])
  @@index([paymentMethod])
  @@index([collectedBy, paymentMethod])
  @@index([paymentDate, amount])
  @@index([feeRecordId])
  @@index([createdAt])
  @@schema("school")
}

model SubscriptionPayment {
  id             String       @id @default(cuid())
  subscriptionId String
  orderId        String
  paymentId      String?
  amount         Float
  currency       String       @default("INR")
  status         String       @default("pending")
  paymentMethod  String       @default("razorpay")
  receiptNumber  String
  paymentDate    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([orderId])
  @@index([paymentId])
  @@schema("saas")
}

model Discount {
  id                   String   @id @default(cuid())
  name                 String
  type                 String
  value                Float
  applicableClasses    String
  applicableCategories String
  maxDiscountAmount    Float?
  isActive             Boolean  @default(true)
  validFrom            String
  validTo              String
  description          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  schoolId             String?

  @@index([schoolId])
  @@schema("school")
}

model AttendanceRecord {
  id        String   @id @default(cuid())
  studentId String
  teacherId String?
  date      String
  status    String
  subject   String?
  class     String?
  section   String?
  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher   Teacher? @relation(fields: [teacherId], references: [id])

  @@unique([studentId, date, subject])
  @@index([date])
  @@index([class])
  @@index([studentId])
  @@index([class, date])
  @@index([status])
  @@schema("school")
}

model Exam {
  id           String       @id @default(cuid())
  name         String
  type         String
  class        String
  section      String?
  subject      String
  date         String
  duration     Int
  totalMarks   Float
  passingMarks Float
  academicYear String       @default("2024-25")
  status       String       @default("scheduled")
  venue        String?
  instructions String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  schoolId     String?
  results      ExamResult[]

  @@index([schoolId])
  @@index([class])
  @@index([status])
  @@index([academicYear])
  @@index([date])
  @@index([class, academicYear])
  @@schema("school")
}

model ExamResult {
  id            String   @id @default(cuid())
  examId        String
  studentId     String
  marksObtained Float
  grade         String?
  remarks       String?
  isAbsent      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
  @@schema("school")
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  content     String
  type        String    @default("general")
  targetRoles String
  isActive    Boolean   @default(true)
  publishedAt DateTime  @default(now())
  expiresAt   DateTime?
  createdBy   String?
  schoolId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  school      School?   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@schema("school")
}

model AcademicYear {
  id            String         @id @default(cuid())
  year          String
  name          String
  startDate     String
  endDate       String
  isActive      Boolean        @default(true)
  schoolId      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  classes       Class[]
  feeStructures FeeStructure[]
  mediums       Medium[]
  sections      Section[]
  students      Student[]      @relation("StudentAcademicYear")
  leaveBalances LeaveBalance[]
  leaveApplications LeaveApplication[]
  leaveWorkflows LeaveWorkflow[]
  leaveSettings LeaveSettings[]
  school        School?        @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, year])
  @@index([schoolId])
  @@index([year])
  @@index([isActive])
  @@index([schoolId, isActive])
  @@schema("school")
}

model Medium {
  id             String         @id @default(cuid())
  code           String
  name           String
  description    String?
  isActive       Boolean        @default(true)
  academicYearId String
  schoolId       String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  classes        Class[]
  feeStructures  FeeStructure[]
  academicYear   AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  school         School?        @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, academicYearId, code])
  @@index([schoolId])
  @@index([code])
  @@index([isActive])
  @@index([academicYearId])
  @@index([schoolId, academicYearId])
  @@schema("school")
}

model Class {
  id             String         @id @default(cuid())
  code           String
  name           String
  level          String
  mediumId       String
  academicYearId String
  isActive       Boolean        @default(true)
  schoolId       String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  academicYear   AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  medium         Medium         @relation(fields: [mediumId], references: [id], onDelete: Cascade)
  feeStructures  FeeStructure[]
  sections       Section[]
  school         School?        @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, academicYearId, code])
  @@index([schoolId])
  @@index([code])
  @@index([level])
  @@index([isActive])
  @@index([mediumId])
  @@index([academicYearId])
  @@index([schoolId, academicYearId])
  @@schema("school")
}

model Section {
  id             String       @id @default(cuid())
  code           String
  name           String
  classId        String
  capacity       Int
  roomNumber     String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  academicYearId String
  schoolId       String?
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  class          Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  school         School?      @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, academicYearId, code])
  @@index([schoolId])
  @@index([code])
  @@index([isActive])
  @@index([classId])
  @@index([academicYearId])
  @@index([schoolId, academicYearId])
  @@schema("school")
}

model SchoolSetting {
  id        String   @id @default(cuid())
  schoolId  String   @default("default")
  group     String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, group, key])
  @@index([schoolId])
  @@index([group])
  @@schema("school")
}

model Board {
  id            String         @id @default(cuid())
  code          String
  name          String
  description   String?
  isActive      Boolean        @default(true)
  schoolId      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  feeStructures FeeStructure[]
  school        School?        @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, code])
  @@index([schoolId])
  @@index([code])
  @@index([isActive])
  @@schema("school")
}

model SchoolTiming {
  id        String   @id @default(cuid())
  name      String
  type      String
  startTime String
  endTime   String
  dayOfWeek String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  schoolId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([type])
  @@index([dayOfWeek])
  @@index([sortOrder])
  @@schema("school")
}

model Account {
  id                String      @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              school_User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@schema("school")
}

model Session {
  id           String      @id
  sessionToken String      @unique
  userId       String
  expires      DateTime
  User         school_User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("school")
}

model school_User {
  id           String      @id
  email        String      @unique
  password     String
  firstName    String
  lastName     String
  role         String      @default("admin")
  avatar       String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime
  customRoleId String?
  schoolId     String?
  employeeId   String?     @unique
  Account      Account[]
  Session      Session[]
  teacher      Teacher?
  CustomRole   CustomRole? @relation(fields: [customRoleId], references: [id])
  School       School?     @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([customRoleId])
  @@index([schoolId])
  @@index([employeeId])
  @@map("User")
  @@schema("school")
}

model school_VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("VerificationToken")
  @@schema("school")
}

model DiscountRequest {
  id               String                    @id @default(cuid())
  schoolId         String
  name             String
  description      String?
  discountType     String
  discountValue    Float
  maxCapAmount     Float?
  scope            String
  targetType       String
  feeStructureIds  String                    @default("[]")
  studentIds       String                    @default("[]")
  classIds         String                    @default("[]")
  sectionIds       String                    @default("[]")
  transportRouteIds String                   @default("[]")
  metadata         Json?
  academicYear     String
  reason           String
  supportingDoc    String?
  status           String                    @default("pending")
  requestedBy      String
  requestedByEmail String
  requestedByName  String
  requestedAt      DateTime                  @default(now())
  approvedBy       String?
  approvedByEmail  String?
  approvedByName   String?
  approvedAt       DateTime?
  approvalNote     String?
  rejectedBy       String?
  rejectedByEmail  String?
  rejectedAt       DateTime?
  rejectionReason  String?
  appliedBy        String?
  appliedByEmail   String?
  appliedAt        DateTime?
  appliedCount     Int?
  validFrom        String
  validTo          String
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  applications     DiscountApplication[]
  auditLogs        DiscountRequestAuditLog[]

  @@index([schoolId])
  @@index([schoolId, status])
  @@index([schoolId, academicYear])
  @@index([schoolId, status, academicYear])
  @@index([requestedBy])
  @@index([approvedBy])
  @@index([status])
  @@index([createdAt])
  @@schema("school")
}

model DiscountApplication {
  id                String          @id @default(cuid())
  schoolId          String
  discountRequestId String
  studentId         String
  feeRecordId       String?
  feeStructureId    String?
  discountAmount    Float
  previousDiscount  Float
  isReversed        Boolean         @default(false)
  reversedBy        String?
  reversedByEmail   String?
  reversedAt        DateTime?
  reversalReason    String?
  appliedAt         DateTime        @default(now())
  appliedBy         String
  appliedByEmail    String
  feeArrearsId      String?
  discountRequest   DiscountRequest @relation(fields: [discountRequestId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([schoolId, studentId])
  @@index([discountRequestId])
  @@index([studentId])
  @@index([feeRecordId])
  @@index([feeArrearsId])
  @@index([studentId, feeRecordId])
  @@index([schoolId, isReversed])
  @@schema("school")
}

model DiscountRequestAuditLog {
  id                String          @id @default(cuid())
  schoolId          String
  discountRequestId String
  action            String
  actorUserId       String
  actorEmail        String
  actorName         String
  actorRole         String
  previousStatus    String?
  newStatus         String?
  details           String?
  ipAddress         String?
  createdAt         DateTime        @default(now())
  discountRequest   DiscountRequest @relation(fields: [discountRequestId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([discountRequestId])
  @@index([schoolId, createdAt])
  @@index([actorEmail])
  @@index([action])
  @@schema("school")
}

model StudentPromotion {
  id               String   @id @default(cuid())
  schoolId         String
  studentId        String
  fromClass        String
  toClass          String
  fromSection      String
  toSection        String
  fromAcademicYear String
  toAcademicYear   String
  promotedBy       String
  promotedByEmail  String
  promotedByName   String
  promotionType    String   @default("regular")
  arrearsAmount    Float    @default(0)
  remarks          String?
  promotionDate    DateTime @default(now())
  createdAt        DateTime @default(now())
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([schoolId])
  @@index([fromAcademicYear])
  @@index([toAcademicYear])
  @@index([promotionDate])
  @@schema("school")
}

model FeeArrears {
  id                  String   @id @default(cuid())
  schoolId            String
  studentId           String
  originalFeeRecordId String
  fromAcademicYear    String
  toAcademicYear      String
  amount              Float
  paidAmount          Float    @default(0)
  pendingAmount       Float
  dueDate             String
  status              String   @default("pending")
  remarks             String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  student             Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([schoolId])
  @@index([fromAcademicYear])
  @@index([toAcademicYear])
  @@index([status])
  @@schema("school")
}

model TokenBlacklist {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@schema("school")
}

model Vehicle {
  id              String           @id @default(cuid())
  vehicleNumber   String
  vehicleType     String           @default("bus")
  capacity        Int              @default(40)
  driverName      String
  driverPhone     String
  registrationNo  String?
  insuranceExpiry String?
  fitnessExpiry   String?
  isActive        Boolean          @default(true)
  schoolId        String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  routes          TransportRoute[]

  @@index([schoolId])
  @@index([isActive])
  @@schema("school")
}

model TransportRoute {
  id             String             @id @default(cuid())
  routeNumber    String
  routeName      String
  description    String?
  stops          String             @default("[]")
  vehicleId      String?
  driverName     String?
  driverPhone    String?
  capacity       Int                @default(40)
  monthlyFee     Float              @default(0)
  yearlyFee      Float              @default(0)
  isActive       Boolean            @default(true)
  schoolId       String
  academicYearId String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  students       StudentTransport[]
  vehicle        Vehicle?           @relation(fields: [vehicleId], references: [id])

  @@index([schoolId])
  @@index([isActive])
  @@index([schoolId, academicYearId])
  @@index([schoolId, academicYearId, isActive])
  @@index([routeNumber, academicYearId])
  @@index([vehicleId])
  @@schema("school")
}

model StudentTransport {
  id             String         @id @default(cuid())
  studentId      String
  routeId        String
  pickupStop     String
  dropStop       String?
  monthlyFee     Float
  academicYearId String?
  isActive       Boolean        @default(true)
  assignedAt     DateTime       @default(now())
  route          TransportRoute @relation(fields: [routeId], references: [id])
  student        Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([routeId])
  @@index([academicYearId])
  @@index([studentId, isActive])
  @@index([routeId, isActive])
  @@index([academicYearId, isActive])
  @@index([studentId, routeId, academicYearId])
  @@index([studentId, academicYearId, isActive])
  @@schema("school")
}

model ExpenseCategory {
  id            String            @id @default(cuid())
  name          String
  description   String?
  color         String?
  icon          String?
  parentId      String?
  isActive      Boolean           @default(true)
  schoolId      String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  budgets       Budget[]
  expenses      Expense[]
  parent        ExpenseCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  subcategories ExpenseCategory[] @relation("CategoryHierarchy")

  @@index([schoolId])
  @@index([schoolId, isActive])
  @@index([parentId])
  @@schema("school")
}

model Expense {
  id               String            @id @default(cuid())
  title            String
  description      String?
  amount           Float
  categoryId       String
  dateIncurred     String
  paymentMethod    String?
  status           String            @default("pending")
  priority         String            @default("medium")
  receiptUrl       String?
  receiptNumber    String?
  vendorName       String?
  vendorDetails    String?
  tags             String            @default("[]")
  requestedBy      String
  requestedByName  String?
  requestedByEmail String?
  requestedAt      DateTime          @default(now())
  approvedBy       String?
  approvedByName   String?
  approvedAt       DateTime?
  approvalNote     String?
  rejectedBy       String?
  rejectedAt       DateTime?
  rejectionReason  String?
  paidBy           String?
  paidAt           DateTime?
  remarks          String?
  academicYear     String            @default("2024-25")
  academicYearId   String?
  schoolId         String?
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  budgetItems      BudgetItem[]
  category         ExpenseCategory   @relation(fields: [categoryId], references: [id])
  auditLogs        ExpenseAuditLog[]

  @@index([schoolId])
  @@index([schoolId, status])
  @@index([schoolId, academicYear])
  @@index([schoolId, categoryId])
  @@index([schoolId, createdAt(sort: Desc)])
  @@index([schoolId, dateIncurred])
  @@index([schoolId, status, academicYear])
  @@index([schoolId, categoryId, dateIncurred])
  @@index([requestedBy])
  @@index([deletedAt])
  @@index([status])
  @@index([dateIncurred])
  @@schema("school")
}

model Budget {
  id              String           @id @default(cuid())
  name            String
  description     String?
  totalAmount     Float
  spentAmount     Float            @default(0)
  remainingAmount Float
  categoryId      String?
  academicYear    String           @default("2024-25")
  academicYearId  String?
  status          String           @default("active")
  startDate       String
  endDate         String
  alertThreshold  Float            @default(80)
  createdBy       String
  createdByName   String?
  schoolId        String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  category        ExpenseCategory? @relation(fields: [categoryId], references: [id])
  items           BudgetItem[]

  @@index([schoolId])
  @@index([schoolId, status])
  @@index([schoolId, academicYear])
  @@index([schoolId, categoryId])
  @@index([status])
  @@schema("school")
}

model BudgetItem {
  id        String   @id @default(cuid())
  budgetId  String
  expenseId String
  amount    Float
  notes     String?
  createdAt DateTime @default(now())
  budget    Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  expense   Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@unique([budgetId, expenseId])
  @@index([budgetId])
  @@index([expenseId])
  @@schema("school")
}

model ExpenseAuditLog {
  id         String   @id @default(cuid())
  schoolId   String
  expenseId  String
  action     String
  actorId    String
  actorEmail String
  actorName  String?
  actorRole  String?
  prevStatus String?
  newStatus  String?
  details    String?
  createdAt  DateTime @default(now())
  expense    Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([expenseId])
  @@index([schoolId, createdAt(sort: Desc)])
  @@index([actorEmail])
  @@schema("school")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  priority  String    @default("medium")
  metadata  String?
  schoolId  String?
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([userId, isRead])
  @@index([schoolId])
  @@index([createdAt(sort: Desc)])
  @@schema("school")
}

// Leave Management Models
model LeaveType {
  id                String    @id @default(cuid())
  schoolId          String
  name              String
  code              String
  maxDaysPerYear    Decimal?
  isPaid            Boolean   @default(true)
  requiresDocument  Boolean   @default(false)
  accrualRate       Decimal?
  canCarryForward   Boolean   @default(true)
  maxCarryForwardDays Decimal?
  description       String?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  school            School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  leaveBalances     LeaveBalance[]
  leaveApplications  LeaveApplication[]
  leaveWorkflows    LeaveWorkflow[]

  @@unique([schoolId, code])
  @@index([schoolId])
  @@index([code])
  @@schema("school")
}

model LeaveBalance {
  id               String    @id @default(cuid())
  staffId          String
  leaveTypeId      String
  academicYearId   String
  totalAllocated   Decimal   @default(0)
  used             Decimal   @default(0)
  balance          Decimal   @default(0)
  carriedForward   Decimal   @default(0)
  lastAccrualDate  DateTime?
  schoolId         String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  staff            Teacher      @relation(fields: [staffId], references: [id], onDelete: Cascade)
  leaveType        LeaveType    @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  academicYear     AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  school           School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  leaveApplications LeaveApplication[]

  @@unique([staffId, leaveTypeId, academicYearId])
  @@index([staffId])
  @@index([leaveTypeId])
  @@index([academicYearId])
  @@schema("school")
}

model LeaveApplication {
  id               String    @id @default(cuid())
  staffId          String
  leaveTypeId      String
  startDate        DateTime
  endDate          DateTime
  totalDays        Decimal
  reason           String?
  attachmentPath   String?
  status           String    @default("pending")
  appliedAt        DateTime  @default(now())
  approverId       String?
  approvedAt       DateTime?
  approvalComments String?
  rejectionReason  String?
  academicYearId   String
  schoolId         String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  staff            Teacher               @relation(fields: [staffId], references: [id], onDelete: Cascade)
  leaveType        LeaveType             @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  approver         Teacher?              @relation("LeaveApprover", fields: [approverId], references: [id])
  academicYear     AcademicYear          @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  school           School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  leaveBalance     LeaveBalance[]
  approvalHistory  LeaveApprovalHistory[]

  @@index([staffId])
  @@index([leaveTypeId])
  @@index([status])
  @@index([academicYearId])
  @@index([appliedAt(sort: Desc)])
  @@schema("school")
}

model LeaveApprovalHistory {
  id               String    @id @default(cuid())
  leaveApplicationId String
  approverId       String
  action           String
  comments         String?
  approverRole     String?
  previousStatus   String?
  newStatus        String?
  createdAt        DateTime  @default(now())

  // Relations
  leaveApplication  LeaveApplication @relation(fields: [leaveApplicationId], references: [id], onDelete: Cascade)
  approver         Teacher         @relation("LeaveApprovalApprover", fields: [approverId], references: [id])

  @@index([leaveApplicationId])
  @@index([approverId])
  @@index([createdAt(sort: Desc)])
  @@schema("school")
}

model LeaveWorkflow {
  id                  String    @id @default(cuid())
  schoolId            String
  academicYearId      String
  leaveTypeId         String?
  roleId              String
  requiredPermission  String
  sequence            Int
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  school              School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear       AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  leaveType           LeaveType?   @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  role                CustomRole   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([academicYearId])
  @@index([leaveTypeId])
  @@index([sequence])
  @@schema("school")
}

model LeaveSettings {
  id                    String    @id @default(cuid())
  schoolId              String
  academicYearId        String
  autoApproveDays       Int       @default(1)
  requireDocumentDays   Int       @default(3)
  minStaffCoverage      Int?
  examPeriodRestriction Boolean   @default(true)
  notificationEmails    String?
  workingDays           String?
  halfDayRules          String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  school                School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear         AcademicYear  @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([schoolId, academicYearId])
  @@index([schoolId])
  @@schema("school")
}
